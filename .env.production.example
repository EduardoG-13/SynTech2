# ──────────────────────────────────────────────────────────────
# BrPec — Syntech  ·  Variáveis de Ambiente — PRODUÇÃO
# ──────────────────────────────────────────────────────────────
# Copie este arquivo para .env.production antes do deploy:
#   cp .env.production.example .env.production
#
# IMPORTANTE:
#   • .env.production NÃO deve ser versionado (já está no .gitignore)
#   • Nunca deixe valores reais neste arquivo de exemplo
#   • Todas as variáveis marcadas com [OBRIGATÓRIO] causam erro na inicialização
#     se ausentes em NODE_ENV=production
# ──────────────────────────────────────────────────────────────

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Banco de dados local (SQLite) ────────────────────────────
# Caminho relativo a src/backend/ — criado automaticamente na primeira execução
# Em produção geralmente aponta para um volume persistente (ex: /data/brpec.sqlite)
DB_PATH=./database/brpec.sqlite

# ── Banco de dados remoto (Supabase / PostgreSQL) ────────────
# [OBRIGATÓRIO] — o servidor recusa inicialização sem esta variável fora do modo test
# Formato: postgresql://usuario:senha@host:5432/database?sslmode=require
DATABASE_URL=postgresql://usuario:senha@host:5432/database

# ── Sincronização em nuvem ───────────────────────────────────
# Defina como true para ativar o agendador de outbox (requer DATABASE_URL)
ENABLE_CLOUD_SYNC=true

# ── Segurança de sessão ──────────────────────────────────────
# [OBRIGATÓRIO] — o servidor recusa inicialização sem este valor em produção
# Gere um valor único com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=substitua_por_valor_gerado

# ── Autenticação JWT ─────────────────────────────────────────
# [OBRIGATÓRIO] — o servidor recusa inicialização sem estes valores em produção
# Gere valores únicos com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=substitua_por_chave_forte_access
JWT_REFRESH_SECRET=substitua_por_chave_forte_refresh

# Expiração de tokens (aceita: ms, s, m, h, d)
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
