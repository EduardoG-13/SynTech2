<!-- Indicador de conexão — fixo no TOPO, visível em todas as telas logadas -->
<div id="status-conexao" class="status-conexao online" role="status" aria-live="polite" title="Status de conexão. Toque para sincronizar.">
  <span class="status-dot"></span>
  <span id="status-conexao-txt">Online</span>
  <span id="status-conexao-pend" class="status-pend" style="display:none;"></span>
</div>

