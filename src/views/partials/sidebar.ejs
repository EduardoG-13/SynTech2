<!-- Botão hamburger (só aparece no mobile) -->
<button id="btn-hamburger" class="hamburger" onclick="toggleSidebar()">
  <span></span><span></span><span></span>
</button>
<div id="sidebar-overlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>

<aside id="sidebar">
  <div class="side-logo">
    <span class="logo-icon">🌱</span>
    <span>SyncTech</span>
  </div>

  <nav id="side-nav">
    <% if (perfil==='Infraestrutura' ) { %>
      <!-- Menu da Infraestrutura (recebe e executa chamados) -->
      <button class="active" onclick="window.location.href='/infraestrutura?perfil=Infraestrutura'">
        <span><img src="/public/Icons/alerta.ico" alt="Chamados" /></span> Chamados
      </button>
      <button onclick="window.location.href='/historico?perfil=Infraestrutura'">
        <span>🕓</span> Histórico
      </button>

      <% } else if (perfil==='Gerente' ) { %>
        <!-- Menu do Gerente (visão gerencial: dashboard + infraestrutura) -->
        <button class="active" onclick="window.location.href='/dashboard?perfil=Gerente'">
          <span><img src="/public/Icons/home.ico" alt="Dashboard" /></span> Dashboard
        </button>
        <button onclick="window.location.href='/infraestrutura?perfil=Gerente'">
          <span><img src="/public/Icons/alerta.ico" alt="Infraestrutura" /></span> Infraestrutura
        </button>

        <% } else if (perfil==='Coordenador' ) { %>
          <!-- Menu do Coordenador (valida e exporta movimentações) -->
          <button class="active" onclick="window.location.href='/dashboard?perfil=Coordenador'">
            <span><img src="/public/Icons/home.ico" alt="Dashboard" /></span> Dashboard
          </button>
          <button onclick="window.location.href='/boletas?perfil=Coordenador'">
            <span><img src="/public/Icons/movimentacao.ico" alt="Boletas" /></span> Boletas
          </button>

          <% } else { %>
            <!-- Menu padrão (Capataz) -->
            <button class="active" onclick="window.location.href='/nova-os?perfil=Capataz&retiro=<%= retiro %>'">
              <span><img src="/public/Icons/movimentacao.ico" alt="Nova Boleta" /></span> Nova Boleta
            </button>
            <button onclick="window.location.href='/tarefas?perfil=Capataz&retiro=<%= retiro %>'">
              <span>🕓</span> Histórico
            </button>
            <button onclick="window.location.href='/novo-chamado?perfil=Capataz&retiro=<%= retiro %>'">
              <span><img src="/public/Icons/infra.ico" alt="Abrir chamado" /></span> Abrir Chamado
            </button>
            <% } %>
  </nav>

  <!-- Rodapé da sidebar: Configurações (só Gerente) + Sair (todos) -->
  <div class="side-footer">
    <% if (perfil === 'Gerente') { %>
      <button class="side-config" id="side-config-btn" onclick="window.location.href='/configuracoes?perfil=<%= perfil %>'">
        <span><img src="/public/Icons/configuracao.ico" alt="Configurações" /></span> Configurações
      </button>
    <% } %>
    <button class="side-logout" id="side-logout-btn" onclick="fazerLogout()">
      <span>🚪</span> Sair
    </button>
  </div>

  <script>
    function fazerLogout() {
      localStorage.removeItem('brpec_sessao');
      fetch('/api/auth/logout', { method: 'POST' }).finally(function () {
        window.location.href = '/';
      });
    }

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebar-overlay').classList.toggle('open');
    }
  </script>
</aside>