<!-- Botão hamburger (só aparece no mobile) -->
<button id="btn-hamburger" class="hamburger" onclick="toggleSidebar()">
  <span></span><span></span><span></span>
</button>
<div id="sidebar-overlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>

<aside id="sidebar">
  <div class="side-logo">
    <span class="logo-icon">🌱</span>
    <span>SyncTech</span>
  </div>

  <nav id="side-nav">
    <% if (perfil === 'Capataz') { %>
      <button class="active" onclick="window.location.href='/tarefas?perfil=Capataz&retiro=<%= retiro %>'">
        <span><img src="/public/Icons/home.ico" alt="Início" /></span> Início
      </button>
      <button onclick="window.location.href='/tarefas?perfil=Capataz&retiro=<%= retiro %>'">
        <span><img src="/public/Icons/tarefas.ico" alt="Tarefas" /></span> Tarefas
      </button>
      <button onclick="window.location.href='/boleta?perfil=Capataz&retiro=<%= retiro %>'">
        <span><img src="/public/Icons/movimentacao.ico" alt="Movimentação" /></span> Movimentação
      </button>
      <button onclick="window.location.href='/infraestrutura?perfil=Capataz&retiro=<%= retiro %>'">
        <span><img src="/public/Icons/infra.ico" alt="Infraestrutura" /></span> Infraestrutura
      </button>

    <% } else if (perfil === 'Gerente') { %>
      <button class="active" onclick="window.location.href='/dashboard?perfil=Gerente'">
        <span><img src="/public/Icons/home.ico" alt="Dashboard" /></span> Dashboard
      </button>
      <button onclick="window.location.href='/aprovacoes?perfil=Gerente'">
        <span><img src="/public/Icons/tarefas.ico" alt="Aprovações" /></span> Aprovações
      </button>
      <button onclick="window.location.href='/infraestrutura?perfil=Gerente'">
        <span><img src="/public/Icons/infra.ico" alt="Infraestrutura" /></span> Infraestrutura
      </button>
      <button onclick="window.location.href='/configuracoes?perfil=Gerente'">
        <span><img src="/public/Icons/configuracao.ico" alt="Configurações" /></span> Configurações
      </button>

    <% } else if (perfil === 'Coordenador') { %>
      <button class="active" onclick="window.location.href='/dashboard?perfil=Coordenador'">
        <span><img src="/public/Icons/home.ico" alt="Dashboard" /></span> Dashboard
      </button>
      <button onclick="window.location.href='/boletas?perfil=Coordenador'">
        <span><img src="/public/Icons/movimentacao.ico" alt="Boletas" /></span> Boletas
      </button>

    <% } else if (perfil === 'Infraestrutura') { %>
      <button class="active" onclick="window.location.href='/infraestrutura?perfil=Infraestrutura'">
        <span><img src="/public/Icons/home.ico" alt="Início" /></span> Início
      </button>
      <button onclick="window.location.href='/infraestrutura?perfil=Infraestrutura'">
        <span><img src="/public/Icons/alerta.ico" alt="Chamados" /></span> Chamados
      </button>

    <% } %>
  </nav>

  <button class="side-config" onclick="fazerLogout()">
    <span>🚪</span> Sair
  </button>

  <script>
    function fazerLogout() {
      localStorage.removeItem('brpec_sessao');
      fetch('/api/auth/logout', { method: 'POST' }).finally(function() {
        window.location.href = '/';
      });
    }

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebar-overlay').classList.toggle('open');
    }
  </script>
</aside>
