<%- include('partials/header') %>
  <link rel="stylesheet" href="/public/css/tarefas.css" />

  <div id="device" class="logged">
    <%- include('partials/sidebar') %>

      <div id="app">
        <main class="sucesso-main">

          <div class="sucesso-card">
            <div class="sucesso-icone">
              <span class="material-symbols-rounded ui-icon" aria-hidden="true">check_circle</span>
            </div>
            <h1 id="sucesso-titulo">Registro concluído!</h1>
            <p class="sucesso-sub" id="sucesso-sub">Seu registro foi salvo no dispositivo.</p>

            <!-- Resumo dinâmico do que foi registrado -->
            <div class="sucesso-resumo" id="sucesso-resumo">
              <!-- preenchido via JS -->
            </div>

            <!-- Status de sincronização -->
            <div class="sucesso-sync" id="sucesso-sync">
              <span class="sync-dot"></span>
              <span id="sync-texto">Aguardando envio para a nuvem...</span>
            </div>

            <div class="sucesso-acoes">
              <button class="btn-secundario" id="btn-historico">
                <span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">history</span> Ver histórico
              </button>
              <button class="btn-primario-grande" id="btn-inicio">
                <span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">home</span> Voltar ao início
              </button>
            </div>
          </div>

        </main>
      </div>
  </div>

  <script>
    var PERFIL = '<%= perfil %>';
    var RETIRO = '<%= retiro %>';

    document.addEventListener('DOMContentLoaded', function () {
      // Lê o último registro salvo do localStorage (escrito pela nova-os ao registrar)
      var ultimo = null;
      try { ultimo = JSON.parse(localStorage.getItem('brpec_ultimo_registro') || 'null'); } catch (e) { }

      if (ultimo) {
        preencherResumo(ultimo);
      } else {
        document.getElementById('sucesso-resumo').innerHTML =
          '<p class="sucesso-vazio">Nenhum detalhe disponível.</p>';
      }

      // Botões de ação dependem do perfil
      document.getElementById('btn-historico').addEventListener('click', function () {
        window.location.href = '/historico';
      });
      document.getElementById('btn-inicio').addEventListener('click', function () {
        if (PERFIL === 'Capataz') window.location.href = '/nova-os';
        else if (PERFIL === 'Infraestrutura') window.location.href = '/infraestrutura';
        else if (PERFIL === 'Gerente' || PERFIL === 'Coordenador') window.location.href = '/dashboard';
        else window.location.href = '/';
      });

      // Status de sincronização REAL (não simulado)
      atualizarStatusSync();
      window.addEventListener('online', atualizarStatusSync);
      window.addEventListener('brpec:sincronizacaoConcluida', atualizarStatusSync);
    });

    // Mostra o estado verdadeiro: salvo só localmente x já enviado pra nuvem.
    function atualizarStatusSync() {
      var box = document.getElementById('sucesso-sync');
      var txt = document.getElementById('sync-texto');
      if (!box || !txt) return;

      function aplicar(pendentes) {
        box.classList.remove('ok');
        if (!navigator.onLine) {
          txt.textContent = ' Salvo no aparelho — será enviado quando a conexão voltar.';
        } else if (pendentes > 0) {
          txt.textContent = 'Salvo no aparelho — sincronizando (' + pendentes + ' na fila)...';
        } else {
          box.classList.add('ok');
          txt.textContent = ' Enviado para a nuvem.';
        }
      }

      try {
        if (window.brpecIndexedDb && window.brpecIndexedDb.listarFila) {
          window.brpecIndexedDb.listarFila()
            .then(function (itens) {
              var n = (itens || []).filter(function (i) { return i && i.status !== 'SINCRONIZADO'; }).length;
              aplicar(n);
            })
            .catch(function () { aplicar(0); });
          return;
        }
      } catch (e) { /* IndexedDB indisponível */ }
      aplicar(0);
    }

    function rotuloOperacao(op) {
      var map = {
        'nascimento': { ico: 'nascimento', label: 'Nascimento' },
        'obito': { ico: 'obto', label: 'Morte' },
        'abate': { ico: 'abate', label: 'Abate Interno' },
        'transferencia': { ico: 'movimentacao', label: 'Transferência' },
        'compravenda': { ico: 'movimentacao', label: 'Compra / Venda' },
        'evolucao': { ico: 'evolucao', label: 'Evolução' },
        'manejo': { ico: 'tarefas', label: 'Manejo' },
        'chamado': { ico: 'infra', label: 'Chamado de infraestrutura' },
      };
      return map[op] || { ico: 'concluido', label: op || 'Registro' };
    }

    function preencherResumo(r) {
      var info = rotuloOperacao(r.operacao);
      document.getElementById('sucesso-titulo').textContent = info.label + ' registrado!';

      var html = '';
      html += linhaResumo('Tipo', BRPIcons.html(info.ico, 'label-ico') + ' ' + info.label);
      if (r.data) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">calendar_month</span> Data', r.data);
      if (r.retiro || r.retiro_origem) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">location_on</span> Retiro', r.retiro || r.retiro_origem);
      if (r.retiro_destino) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">location_on</span> Destino', r.retiro_destino);
      if (r.pasto) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">grass</span> Pasto', r.pasto);

      if (r.animais && r.animais.length) {
        var lista = r.animais.map(function (a) { return a.quantidade + ' × ' + a.categoria; }).join('<br>');
        html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">swap_horiz</span> Animais', lista);
        var total = r.animais.reduce(function (s, a) { return s + (parseInt(a.quantidade) || 0); }, 0);
        html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">calculate</span> Total', '<strong>' + total + ' cabeças</strong>');
      }

      if (r.brinco) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">sell</span> Brinco', r.brinco);
      if (r.causa) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">heart_broken</span> Causa', r.causa);
      if (r.valor) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">payments</span> Valor', 'R$ ' + r.valor);
      if (r.titulo) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">assignment</span> Título', r.titulo);
      if (r.observacoes) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">edit</span> Observações', r.observacoes);
      if (r.observacoes_audio) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">mic</span> Áudio', 'Anexado');
      if (r.tem_foto) html += linhaResumo('<span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">photo_camera</span> Foto', 'Anexada');

      document.getElementById('sucesso-resumo').innerHTML = html;
    }

    function linhaResumo(label, valor) {
      return '<div class="resumo-linha"><span class="resumo-label">' + label + '</span><span class="resumo-valor">' + valor + '</span></div>';
    }
  </script>

  <%- include('partials/footer') %>
