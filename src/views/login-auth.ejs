<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/login.css" />

<div id="device" class="login-page">
  <div class="login-logo">
    <img src="/public/syntech-verde.png" alt="Syntech" />
  </div>
  <div class="header-bar">
    <button class="btn-voltar" onclick="window.location.href='/'"><span class="material-symbols-rounded ui-icon back-ico" aria-hidden="true">arrow_back</span> Voltar</button>
    <h1><%= perfil %></h1>
    <div class="sub">Insira suas credenciais para acessar</div>
  </div>

  <form class="login-form" id="form-login" onsubmit="return realizarLogin(event)">
    <div class="form-group">
      <label for="usuario">Usuário <span class="req-star">*</span></label>
      <input type="text" id="usuario" placeholder="Digite seu usuário" required />
    </div>

    <div class="form-group">
      <label for="senha">Senha <span class="req-star">*</span></label>
      <div class="senha-wrapper">
        <input type="password" id="senha" placeholder="Digite sua senha" required />
        <button type="button" class="btn-olho" onclick="toggleSenha()" aria-label="Mostrar senha" aria-pressed="false"><span id="ico-olho" class="material-symbols-rounded ui-icon" aria-hidden="true">visibility</span></button>
      </div>
    </div>

    <button type="submit" class="btn-login">Entrar</button>

    <p class="login-erro" id="login-erro" style="display: none;">Usuário ou senha incorretos.</p>
  </form>
</div>

<script>
  var PERFIL = '<%= perfil %>';

  function toggleSenha() {
    var input = document.getElementById('senha');
    var ico = document.getElementById('ico-olho');
    var mostrando = input.type === 'text';
    input.type = mostrando ? 'password' : 'text';
    var botao = ico && ico.closest('button');
    if (ico) ico.textContent = mostrando ? 'visibility' : 'visibility_off';
    if (botao) {
      botao.setAttribute('aria-label', mostrando ? 'Mostrar senha' : 'Ocultar senha');
      botao.setAttribute('aria-pressed', String(!mostrando));
    }
  }

  function realizarLogin(e) {
    e.preventDefault();
    var usuario = document.getElementById('usuario').value.trim();
    var senha = document.getElementById('senha').value;

    fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ usuario: usuario, senha: senha, perfil: PERFIL })
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.sucesso) {
        window.authClient.setAccessToken(data.accessToken);
        localStorage.setItem('brpec_sessao', JSON.stringify({
          perfil: PERFIL,
          usuario: usuario,
          usuarioId: data.usuario && data.usuario.id,
          logadoEm: new Date().toISOString()
        }));
        // Cada perfil tem sua home dedicada
        var rotaHome = '/dashboard'; // Gerente e Coordenador
        if (PERFIL === 'Capataz') rotaHome = '/tarefas';
        if (PERFIL === 'Infraestrutura') rotaHome = '/infraestrutura';
        window.location.href = rotaHome + '?perfil=' + encodeURIComponent(PERFIL);
      } else {
        document.getElementById('login-erro').style.display = 'block';
      }
    })
    .catch(function() {
      document.getElementById('login-erro').style.display = 'block';
    });

    return false;
  }
</script>

<%- include('partials/footer') %>
