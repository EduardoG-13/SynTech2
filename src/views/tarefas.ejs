<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/tarefas.css" />

<div id="device" class="logged">

  <%- include('partials/sidebar') %>

  <div id="app">

    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><img src="/public/Icons/capataz.ico" alt="Capataz" style="width:32px;height:32px;object-fit:contain;" /></div>
      <h1>Histórico de Registros</h1>
      <div class="sub"><%= retiro %> (<%= perfil %>)</div>
    </div>

    <main class="tarefas-main">

      <!-- Filtro por tipo de boleta (ajuda a achar registros) -->
      <div class="filter-pills" id="filtros-tarefas">
        <button class="pill active" data-filtro="todas">Todas</button>
        <button class="pill" data-filtro="movimentacao"><img class="label-ico" src="/public/Icons/movimentacao.ico" alt="" /> Movimentação</button>
        <button class="pill" data-filtro="nascimento"><img class="label-ico" src="/public/Icons/nascimento.ico" alt="" /> Nascimento</button>
        <button class="pill" data-filtro="obito"><img class="label-ico" src="/public/Icons/obto.ico" alt="" /> Óbito</button>
      </div>

      <!-- Lista de boletas criadas pelo capataz (lidas do localStorage) -->
      <div class="tarefas-lista" id="tarefas-lista"></div>

      <div class="tarefas-vazio" id="tarefas-vazio" style="display: none;">
        <p>Nenhuma boleta encontrada.</p>
      </div>

      <button class="btn btn-primario" style="width: 100%; margin-top: 1.5rem;" onclick="window.location.href='/nova-os?perfil=<%= perfil %>&retiro=<%= retiro %>'">
        ➕ Nova Boleta
      </button>

    </main>

  </div>
</div>

<script>
  (function() {
    var ICONES = {
      'movimentacao': 'movimentacao', 'transferencia': 'movimentacao',
      'nascimento': 'nascimento', 'obito': 'obto',
      'compravenda': 'movimentacao', 'evolucao': 'movimentacao', 'manejo': 'tarefas'
    };
    var ROTULOS = {
      'movimentacao': 'Movimentação', 'transferencia': 'Transferência',
      'nascimento': 'Nascimento', 'obito': 'Óbito',
      'compravenda': 'Compra/Venda', 'evolucao': 'Evolução', 'manejo': 'Manejo'
    };

    var lista = [];
    var cont = document.getElementById('tarefas-lista');
    var vazio = document.getElementById('tarefas-vazio');

    cont.innerHTML = '<p style="text-align:center; color:#8A8A7C; padding:1rem;">Carregando boletas...</p>';

    fetch('/api/boletas/minhas', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(rows) {
        lista = rows || [];
        render('todas');
      })
      .catch(function() {
        cont.innerHTML = '<p style="color:#D32F2F; text-align:center;">Erro ao carregar boletas.</p>';
      });

    function render(filtro) {
      cont.innerHTML = '';
      var visiveis = 0;
      lista.forEach(function(r) {
        var tipo = r.operacao || 'manejo';
        // Filtro "obito"/"nascimento"/"movimentacao" — "movimentacao" engloba transferencia/compravenda/evolucao
        var grupo = (tipo === 'transferencia' || tipo === 'compravenda' || tipo === 'evolucao') ? 'movimentacao' : tipo;
        if (filtro !== 'todas' && grupo !== filtro) return;

        var ico = ICONES[tipo] || 'tarefas';
        var rotulo = ROTULOS[tipo] || 'Registro';
        var total = (r.animais || []).reduce(function(s,a){return s+(parseInt(a.quantidade)||0);},0);
        var desc = total ? (total + ' cabeças') : (r.titulo || r.causa || '');
        var data = r.data || (r.criadoEm || '').slice(0,10);
        var statusBadge = r.aprovada
          ? '<span class="badge concluida">✅ Aprovada</span>'
          : '<span class="badge pendente">⏳ Aguardando coordenador</span>';

        var card = document.createElement('div');
        card.className = 'card tarefa-card';
        card.dataset.tipo = grupo;
        card.onclick = function() { window.location.href = '/boleta/' + r.id; };
        card.innerHTML =
          '<div class="bar-lateral ' + (r.aprovada ? 'concluida' : 'pendente') + '"></div>' +
          '<div class="body">' +
            '<div class="info">' +
              '<span class="titulo"><img class="label-ico" src="/public/Icons/' + ico + '.ico" alt="" /> ' + rotulo + '</span>' +
              '<span class="descricao">' + desc + '</span>' +
              '<div class="meta"><span class="retiro-tag">📅 ' + data + '</span></div>' +
            '</div>' +
            '<div class="status-area">' +
              statusBadge +
              '<span class="arrow">›</span>' +
            '</div>' +
          '</div>';
        cont.appendChild(card);
        visiveis++;
      });
      vazio.style.display = visiveis === 0 ? 'block' : 'none';
    }

    document.querySelectorAll('#filtros-tarefas .pill').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('#filtros-tarefas .pill').forEach(function(b){b.classList.remove('active');});
        btn.classList.add('active');
        render(btn.dataset.filtro);
      });
    });
  })();
</script>

<%- include('partials/footer') %>
