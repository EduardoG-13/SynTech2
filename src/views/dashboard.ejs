<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/dashboard.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div id="device" class="logged">
  <%- include('partials/sidebar') %>

  <div id="app">
    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><img src="/public/Icons/<%= perfil === 'Coordenador' ? 'coordenador' : 'gerente' %>.ico" alt="<%= perfil %>" style="width:32px;height:32px;object-fit:contain;" /></div>
      <h1>Dashboard</h1>
      <div class="sub"><%= typeof nome !== 'undefined' ? nome : '' %> · <%= perfil %></div>
    </div>

    <main class="dashboard-main">

      <div class="card" style="margin-bottom: 1rem; padding: 1rem;">
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
          <select id="filter-retiro" style="flex: 1; min-width:160px; padding: 0.5rem; border: 1px solid #ccc; border-radius: 8px;">
            <option value="">Todos os retiros</option>
          </select>
          <input type="date" id="filter-data" style="flex: 1; min-width:140px; padding: 0.5rem; border: 1px solid #ccc; border-radius: 8px;" />
          <button id="btn-exportar-dashboard" class="btn btn-secundario-laranja" style="white-space:nowrap;">
            <img class="label-ico" src="/public/Icons/sincronizacao.ico" alt="" /> Exportar planilha
          </button>
        </div>
      </div>

      <!-- KPIs -->
      <div class="db-stats" style="margin-bottom: 1rem;">
        <div class="card db-stat-card" style="padding: 1rem;">
          <p class="db-stat-card__label">📝 Boletas (total)</p>
          <div class="db-stat-card__value" id="stat-boletas-total">—</div>
        </div>
        <div class="card db-stat-card" style="padding: 1rem;">
          <p class="db-stat-card__label">⏳ Pendentes</p>
          <div class="db-stat-card__value" id="stat-pendentes">—</div>
        </div>
        <div class="card db-stat-card" style="padding: 1rem;">
          <p class="db-stat-card__label">✓ Aprovadas</p>
          <div class="db-stat-card__value" id="stat-aprovadas">—</div>
        </div>
        <div class="card db-stat-card" style="padding: 1rem;">
          <p class="db-stat-card__label">🐂 Cabeças</p>
          <div class="db-stat-card__value" id="stat-cabecas">—</div>
        </div>
        <div class="card db-stat-card" style="padding: 1rem;">
          <p class="db-stat-card__label">🛠️ Chamados abertos</p>
          <div class="db-stat-card__value" id="stat-alertas">—</div>
        </div>
      </div>

      <div class="db-charts" style="margin-bottom: 1rem;">
        <div class="card" style="padding: 1rem;">
          <h3>Boletas por tipo</h3>
          <div class="db-chart-wrap">
            <canvas id="chart-tipo" role="img" aria-label="Gráfico de barras: boletas por tipo"></canvas>
          </div>
        </div>
        <div class="card" style="padding: 1rem;">
          <h3>Evolução mensal de boletas</h3>
          <div class="db-chart-wrap">
            <canvas id="chart-mes" role="img" aria-label="Gráfico de linha: boletas por mês"></canvas>
          </div>
        </div>
      </div>

      <div class="db-charts" style="margin-bottom: 1rem;">
        <div class="card" style="padding: 1rem;">
          <h3>Chamados por retiro</h3>
          <div class="db-chart-wrap">
            <canvas id="chart-chamados" role="img" aria-label="Gráfico de barras: chamados em aberto por retiro"></canvas>
          </div>
        </div>
        <div class="card" style="padding: 1rem;">
          <h3>Chamados por status</h3>
          <div class="db-chart-wrap db-chart-wrap--donut">
            <canvas id="chart-status" role="img" aria-label="Gráfico de rosca: chamados por status"></canvas>
          </div>
        </div>
      </div>

      <% if (perfil === 'Gerente') { %>
      <!-- Fechamento por período (só Gerente) -->
      <div class="card" style="margin-bottom: 1rem; padding: 1rem;">
        <h3><img class="label-ico" src="/public/Icons/bloqueado.ico" alt="" /> Fechamento de período</h3>
        <p style="font-size:0.85rem; color:#5c6b5d; margin-bottom:0.75rem;">
          Escolha o intervalo (de — até). Todas as boletas do período ficam <strong>travadas</strong> — nem o capataz edita. Use no fim do ciclo contábil.
        </p>
        <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:flex-end;">
          <div>
            <label style="display:block; font-size:0.75rem; color:#5c6b5d;">De</label>
            <input type="date" id="fechar-de" style="padding:0.5rem; border:1px solid #ccc; border-radius:8px;" />
          </div>
          <div>
            <label style="display:block; font-size:0.75rem; color:#5c6b5d;">Até</label>
            <input type="date" id="fechar-ate" style="padding:0.5rem; border:1px solid #ccc; border-radius:8px;" />
          </div>
          <button id="btn-fechar-mes" class="btn btn-primario" style="white-space:nowrap;">🔒 Fechar período</button>
          <button id="btn-planilha-oficial" class="btn btn-secundario-laranja" style="white-space:nowrap;">📑 Planilha oficial (boletas + chamados)</button>
        </div>
        <p id="fechar-msg" style="display:none; margin-top:0.5rem; font-weight:600;"></p>
        <div id="lista-fechamentos" style="margin-top:1rem;"></div>
      </div>
      <% } %>

      <!-- Lista de retiros: status operacional -->
      <div class="card" style="margin-bottom: 1rem; padding: 1rem;">
        <h3><img class="label-ico" src="/public/Icons/localizacao.ico" alt="" /> Retiros da fazenda</h3>
        <div id="lista-retiros-dashboard" class="retiros-grid"></div>
      </div>

    </main>

    <%- include('partials/bottom-nav') %>
  </div>
</div>

<script>window.DASHBOARD_USUARIO_ID = '<%= typeof usuario_id !== "undefined" ? usuario_id : "" %>';</script>
<script src="/public/js/dashboard.js"></script>
<%- include('partials/footer') %>
