<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/dashboard.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div id="device" class="logged">
  <%- include('partials/sidebar') %>

  <div id="app">
    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><img src="/public/Icons/<%= perfil === 'Coordenador' ? 'coordenador' : 'gerente' %>.ico" alt="<%= perfil %>" style="width:32px;height:32px;object-fit:contain;" /></div>
      <h1>Dashboard</h1>
      <div class="sub"><%= perfil %></div>
    </div>

    <main class="dashboard-main">

      <div class="card" style="margin-bottom: 1rem; padding: 1rem;">
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          <select id="filter-retiro" style="flex: 1; padding: 0.5rem; border: 1px solid #ccc; border-radius: 8px;">
            <option value="">Todos os retiros</option>
          </select>
          <input type="date" id="filter-data" style="flex: 1; padding: 0.5rem; border: 1px solid #ccc; border-radius: 8px;" />
        </div>
      </div>

      <div class="db-stats" style="margin-bottom: 1rem;">
        <div class="card db-stat-card" style="padding: 1rem;">
          <p class="db-stat-card__label">Alertas em aberto</p>
          <div class="db-stat-card__value" id="stat-alertas">—</div>
        </div>
        <div class="card db-stat-card" style="padding: 1rem;">
          <p class="db-stat-card__label">Prioridades</p>
          <div class="db-stat-card__value" id="stat-prioridades">—</div>
        </div>
        <div class="card db-stat-card" style="padding: 1rem;">
          <p class="db-stat-card__label">Evolução</p>
          <div class="db-stat-card__value" id="stat-evolucao">—%</div>
        </div>
      </div>

      <div class="db-charts" style="margin-bottom: 1rem;">
        <div class="card" style="padding: 1rem;">
          <h3>Chamados por retiro</h3>
          <div class="db-chart-wrap">
            <canvas id="chart-chamados" role="img" aria-label="Gráfico de barras: chamados em aberto por retiro"></canvas>
          </div>
        </div>
        <div class="card" style="padding: 1rem;">
          <h3>Chamados por status</h3>
          <div class="db-chart-wrap db-chart-wrap--donut">
            <canvas id="chart-status" role="img" aria-label="Gráfico de rosca: chamados por status"></canvas>
          </div>
        </div>
      </div>

      <!-- Lista de retiros: status operacional -->
      <div class="card" style="margin-bottom: 1rem; padding: 1rem;">
        <h3>🏠 Retiros da fazenda</h3>
        <div id="lista-retiros-dashboard" class="retiros-grid"></div>
      </div>

    </main>

    <%- include('partials/bottom-nav') %>
  </div>
</div>

<script>window.DASHBOARD_USUARIO_ID = '<%= typeof usuario_id !== "undefined" ? usuario_id : "" %>';</script>
<script src="/public/js/dashboard.js"></script>
<%- include('partials/footer') %>
