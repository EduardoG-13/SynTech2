<%- include('partials/header') %>

<div id="device" class="logged">
  <%- include('partials/sidebar') %>

  <div id="app">
    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><img src="/public/Icons/capataz.ico" alt="Capataz" style="width:32px;height:32px;object-fit:contain;" /></div>
      <h1>Concluir Tarefa</h1>
      <div class="sub"><%= retiro %> (<%= perfil %>)</div>
    </div>

    <main class="layout" style="padding: 0;">

      <button class="btn-voltar" onclick="window.history.back()">← Voltar</button>

      <div class="card" style="margin-bottom: 1rem; background: var(--verde-profundo, #1A4D2E); color: #fff; text-align: center; padding: 1rem;">
        <h2 id="tarefa-titulo-concluir">Nome da Tarefa</h2>
      </div>

      <div class="card" style="margin-bottom: 1rem;">
        <h3>Foto da Conclusão</h3>
        <div class="upload-area" id="area-foto">
          <label for="input-foto" class="upload-label">
            <span class="upload-icon"><img src="/public/Icons/tira_foto.ico" alt="" style="width:48px;height:48px;object-fit:contain;" /></span>
            <span>Clique ou arraste uma imagem</span>
          </label>
          <input type="file" id="input-foto" accept="image/*" capture="environment" style="display: none;" />
          <img id="preview-foto" src="" alt="Preview" style="display: none; max-width: 100%; border-radius: 8px; margin-top: 0.5rem;" />
        </div>
      </div>

      <div class="card" style="margin-bottom: 1rem;">
        <h3>Observações</h3>
        <textarea id="observacoes" rows="4" placeholder="Relate problemas encontrados ou detalhes da execução..." style="width: 100%; border: 1px solid #ccc; border-radius: 8px; padding: 0.75rem; font-family: inherit; resize: vertical;"></textarea>
      </div>

      <div class="card" style="margin-bottom: 1rem;">
        <h3>Gravar Áudio</h3>
        <div class="audio-recorder">
          <button class="btn btn-secundario" id="btn-gravar" style="width: 100%;">
            <img class="label-ico" src="/public/Icons/grava_audio.ico" alt="" /> Grave seu áudio
          </button>
          <audio id="audio-gravado" controls style="width: 100%; display: none; margin-top: 0.5rem;"></audio>
        </div>
      </div>

      <div class="acoes-concluir" style="display: flex; gap: 1rem; margin-top: 1rem;">
        <button class="btn btn-secundario" id="btn-tirar-foto" style="flex: 1;">
          <img class="label-ico" src="/public/Icons/tira_foto.ico" alt="" /> Tirar Foto
        </button>
        <button class="btn btn-primario" id="btn-salvar" style="flex: 1;">
          <img class="label-ico" src="/public/Icons/salvar.ico" alt="" /> Salvar
        </button>
      </div>

    </main>
  </div>
</div>

<%- include('partials/footer') %>
