<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>BRPec | Registro de nascimento</title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div>
        <p class="eyebrow">US08 -> UC06 -> RN27</p>
        <h1>Registro de nascimento de bezerro</h1>
      </div>
      <a href="/health" class="health-link">Health</a>
    </header>

    <main class="layout">
      <section class="panel form-panel" aria-labelledby="form-title">
        <div class="section-title">
          <div>
            <p class="eyebrow">Fluxo testado</p>
            <h2 id="form-title">Boleta digital</h2>
          </div>
          <button id="seedButton" class="secondary-button" type="button">Preparar demo</button>
        </div>

        <form id="birthForm" novalidate>
          <div class="field-grid">
            <label>
              Retiro
              <input name="retiroId" value="retiro-barra-bonita" required />
            </label>

            <label>
              Responsável
              <input name="responsavelId" value="usuario-capataz-1" required />
            </label>

            <label>
              Categoria
              <select name="categoria" required>
                <option value="bezerro">Bezerro</option>
                <option value="bezerra">Bezerra</option>
                <option value="garrote">Garrote</option>
                <option value="novilha">Novilha</option>
                <option value="vaca">Vaca</option>
                <option value="boi_touro">Boi/Touro</option>
              </select>
            </label>

            <label>
              Data
              <input name="dataMovimentacao" type="date" value="2026-05-21" required />
            </label>

            <label>
              Quantidade
              <input name="quantidade" type="number" min="1" value="3" required />
            </label>

            <label>
              Raça
              <input name="raca" value="nelore" />
            </label>
          </div>

          <label>
            Observações
            <textarea name="observacoes" rows="4">Registro feito no retiro durante a rotina da manha</textarea>
          </label>

          <div class="actions">
            <button type="submit">Registrar nascimento</button>
            <button id="businessErrorButton" class="ghost-button" type="button">Simular quantidade 0</button>
            <button id="databaseErrorButton" class="ghost-button" type="button">Simular FK inválida</button>
          </div>
        </form>
      </section>

      <aside class="panel status-panel" aria-labelledby="status-title">
        <p class="eyebrow">Retorno da API</p>
        <h2 id="status-title">Resultado</h2>
        <div id="statusMessage" class="status neutral">Prepare os dados da demo ou envie o formulário.</div>
        <pre id="responseOutput">{}</pre>
      </aside>

      <section class="panel list-panel" aria-labelledby="list-title">
        <div class="section-title">
          <div>
            <p class="eyebrow">Persistência real</p>
            <h2 id="list-title">Nascimentos salvos</h2>
          </div>
          <button id="refreshButton" class="secondary-button" type="button">Atualizar</button>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Data</th>
                <th>Retiro</th>
                <th>Categoria</th>
                <th>Qtd.</th>
                <th>Status sync</th>
                <th>Fila</th>
              </tr>
            </thead>
            <tbody id="recordsBody">
              <tr>
                <td colspan="6">Nenhum registro carregado.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <script src="/public/app.js"></script>
  </body>
</html>
