<%- include('partials/header') %>

<div id="device" class="login-page">
  <div style="text-align: center; padding: 3rem 1.5rem; max-width: 480px; margin: 0 auto;">
    <div style="margin-bottom: 1rem;"><img src="/public/Icons/acesso_restrito.ico" alt="" style="width:72px; height:72px; object-fit:contain;" /></div>
    <h1 style="color: #1A4D2E; margin-bottom: 1rem;">Acesso restrito</h1>
    <p style="color: #5c6b5d; font-size: 1rem; margin-bottom: 0.5rem;">
      Esta área é exclusiva para perfis: <strong><%= perfilNecessario %></strong>
    </p>
    <p style="color: #8A8A7C; font-size: 0.9rem; margin-bottom: 2rem;">
      Você está logado como <strong><%= perfil %></strong>.
    </p>
    <button onclick="window.location.href='/'"
            style="background: #1A4D2E; color: #fff; border: none; border-radius: 12px; padding: 0.85rem 2rem; font-weight: 700; font-size: 1rem; cursor: pointer;">
      ⬅️ Voltar ao login
    </button>
  </div>
</div>

<%- include('partials/footer') %>
