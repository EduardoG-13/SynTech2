<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/login.css" />

<div id="device" class="login-page">
  <div class="login-logo">
    <img src="/public/syntech-verde.png" alt="Syntech" />
  </div>
  <div class="header-bar">
    <div class="sub">Selecione seu perfil para continuar</div>
  </div>

  <div class="perfil-grid">
    <a href="/selecionar-retiro" class="perfil-btn-link">
      <button class="perfil-btn">
        <span class="ic"><img src="/public/Icons/capataz.ico" alt="" /></span>
        <span class="lbl">Capataz</span>
      </button>
    </a>

    <a href="/selecionar-categoria-infra" class="perfil-btn-link">
      <button class="perfil-btn">
        <span class="ic"><img src="/public/Icons/infra.ico" alt="" /></span>
        <span class="lbl">Infraestrutura</span>
      </button>
    </a>

    <a href="/login-auth?perfil=Coordenador" class="perfil-btn-link">
      <button class="perfil-btn">
        <span class="ic"><img src="/public/Icons/coordenador.ico" alt="" /></span>
        <span class="lbl">Coordenador</span>
      </button>
    </a>

    <a href="/login-auth?perfil=Gerente" class="perfil-btn-link">
      <button class="perfil-btn">
        <span class="ic"><img src="/public/Icons/gerente.ico" alt="" /></span>
        <span class="lbl">Gerente</span>
      </button>
    </a>
  </div>
</div>

<script>
  // Auto-redirect SÓ se houver sessão VÁLIDA no servidor (cookie ativo).
  // Antes redirecionava só pelo localStorage e quando o cookie expirava dava loop.
  (function() {
    function redirecionar(usuario) {
      var perfil = usuario.perfil;
      if (perfil === 'Capataz') {
        window.location.href = '/tarefas';
      } else if (perfil === 'Infraestrutura') {
        window.location.href = '/infraestrutura';
      } else if (perfil === 'Gerente' || perfil === 'Coordenador') {
        window.location.href = '/dashboard';
      }
    }

    function verificarSessao() {
      return fetch('/api/auth/me', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.usuario) {
          return false;
        }
        redirecionar(data.usuario);
        return true;
      });
    }

    verificarSessao()
      .then(function(logado) {
        if (logado || !window.authClient.getAccessToken()) return;
        return window.authClient.refreshAccessToken().then(verificarSessao);
      })
      .catch(function() {
        // Sem conexão — limpa cache de sessão local pra não criar loop
        window.authClient.clearSession();
        localStorage.removeItem('brpec_sessao');
      });
  })();
</script>

<%- include('partials/footer') %>
