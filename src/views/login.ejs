<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/login.css" />

<div id="device" class="login-page">
  <div class="header-bar">
    <h1>SyncTech</h1>
    <div class="sub">Selecione seu perfil para continuar</div>
  </div>

  <div class="perfil-grid">
    <a href="/selecionar-retiro" class="perfil-btn-link">
      <button class="perfil-btn">
        <span class="ic"><img src="/public/Icons/capataz.ico" alt="Capataz" /></span>
        <span class="lbl">Capataz</span>
      </button>
    </a>

    <a href="/selecionar-categoria-infra" class="perfil-btn-link">
      <button class="perfil-btn">
        <span class="ic"><img src="/public/Icons/infra.ico" alt="Infraestrutura" /></span>
        <span class="lbl">Infraestrutura</span>
      </button>
    </a>

    <a href="/login-auth?perfil=Coordenador" class="perfil-btn-link">
      <button class="perfil-btn">
        <span class="ic"><img src="/public/Icons/coordenador.ico" alt="Coordenador" /></span>
        <span class="lbl">Coordenador</span>
      </button>
    </a>

    <a href="/login-auth?perfil=Gerente" class="perfil-btn-link">
      <button class="perfil-btn">
        <span class="ic"><img src="/public/Icons/gerente.ico" alt="Gerente" /></span>
        <span class="lbl">Gerente</span>
      </button>
    </a>
  </div>
</div>

<script>
  (function() {
    var sessao = localStorage.getItem('brpec_sessao');
    if (sessao) {
      try {
        var dados = JSON.parse(sessao);
        if (dados.perfil === 'Capataz' && dados.retiro) {
          window.location.href = '/tarefas?perfil=Capataz&retiro=' + encodeURIComponent(dados.retiro);
        } else if (dados.perfil === 'Infraestrutura') {
          window.location.href = '/infraestrutura?perfil=Infraestrutura';
        } else if (dados.perfil) {
          // Gerente e Coordenador
          window.location.href = '/dashboard?perfil=' + encodeURIComponent(dados.perfil);
        }
      } catch(e) {}
    }
  })();
</script>

<%- include('partials/footer') %>
