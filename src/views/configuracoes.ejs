<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/configuracoes.css" />

<div id="device" class="logged">
  <%- include('partials/sidebar') %>

  <div id="app">
    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><span class="material-symbols-rounded ui-icon" aria-hidden="true">manage_accounts</span></div>
      <h1>Configurações</h1>
      <div class="sub">Gestão de retiros e usuários (Gerente)</div>
    </div>

    <main class="config-main">

      <!-- Abas -->
      <div class="config-abas">
        <button class="aba active" data-aba="retiros"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">home</span> Retiros</button>
        <button class="aba" data-aba="usuarios"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">engineering</span> Usuários</button>
        <button class="aba" data-aba="dispositivos"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">install_mobile</span> Dispositivos</button>
        <button class="aba" data-aba="auditoria"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">assignment</span> Auditoria</button>
      </div>

      <!-- Aviso de acesso -->
      <div class="config-aviso" id="config-aviso" style="display:none;">
        <span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">shield_lock</span> Acesso restrito. Faça login como <strong>Gerente</strong> para gerenciar.
      </div>

      <!-- ================= ABA RETIROS ================= -->
      <section class="aba-conteudo" id="conteudo-retiros">

        <div class="card-config">
          <h2><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">location_on</span> Novo retiro</h2>
          <form id="form-retiro" class="grid-form">
            <input type="hidden" id="ret-id" />
            <div>
              <label>Nome do retiro <span class="req-star">*</span></label>
              <input type="text" id="ret-nome" placeholder="Ex: Acurizal" required />
            </div>
            <div>
              <label>Número <span class="opcional-txt">(opcional)</span></label>
              <input type="text" id="ret-numero" placeholder="Ex: 01" />
            </div>
            <div>
              <label>Localização <span class="opcional-txt">(opcional)</span></label>
              <input type="text" id="ret-local" placeholder="Ex: Sede Acurizal" />
            </div>
            <div>
              <label>Capataz responsável <span class="opcional-txt">(opcional)</span></label>
              <select id="ret-capataz"><option value="">— Sem capataz —</option></select>
            </div>
            <div>
              <label>Coordenador <span class="opcional-txt">(opcional)</span></label>
              <select id="ret-coord"><option value="">— Sem coordenador —</option></select>
            </div>
            <div class="form-acoes">
              <button type="submit" class="btn-salvar" id="ret-btn-salvar"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">save</span> Salvar retiro</button>
              <button type="button" class="btn-cancelar" id="ret-btn-cancelar" style="display:none;">Cancelar</button>
            </div>
          </form>
        </div>

        <div class="card-config">
          <h2><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">assignment</span> Retiros cadastrados</h2>
          <div id="lista-retiros-admin" class="lista-admin"></div>
        </div>

      </section>

      <!-- ================= ABA USUÁRIOS ================= -->
      <section class="aba-conteudo" id="conteudo-usuarios" style="display:none;">

        <div class="card-config">
          <h2><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">engineering</span> Novo usuário</h2>
          <form id="form-usuario" class="grid-form">
            <input type="hidden" id="usr-id" />
            <div>
              <label>Nome (login) <span class="req-star">*</span></label>
              <input type="text" id="usr-nome" placeholder="Ex: marcos" required />
            </div>
            <div>
              <label>Senha <span class="req-star">*</span></label>
              <input type="password" id="usr-senha" placeholder="Senha de acesso" />
              <small id="usr-senha-hint" style="display:none; color:#5c6b5d;">Deixe em branco para manter a senha atual</small>
            </div>
            <div>
              <label>Perfil <span class="req-star">*</span></label>
              <select id="usr-perfil">
                <option value="Coordenador">Coordenador</option>
                <option value="Gerente">Gerente</option>
                <option value="Capataz">Capataz</option>
                <option value="Tecnico">Técnico de Infraestrutura</option>
              </select>
            </div>
            <div id="usr-retiro-wrap" style="display:none;">
              <label>Retiro <span class="req-star">*</span></label>
              <select id="usr-retiro"><option value="">— Sem retiro —</option></select>
            </div>
            <div id="usr-admin-wrap" style="display:none;">
              <label style="display:flex; align-items:center; gap:0.5rem;">
                <input type="checkbox" id="usr-is-admin" />
                <span><span class="material-symbols-rounded ui-icon ico-sm" aria-hidden="true">lock</span> Administrador (acessa Configurações)</span>
              </label>
              <small style="color:#5c6b5d;">Marque para conceder acesso à tela de Configurações.</small>
            </div>
            <div class="form-acoes">
              <button type="submit" class="btn-salvar" id="usr-btn-salvar"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">save</span> Salvar usuário</button>
              <button type="button" class="btn-cancelar" id="usr-btn-cancelar" style="display:none;">Cancelar</button>
            </div>
          </form>
        </div>

        <div class="card-config">
          <h2><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">engineering</span> Usuários cadastrados</h2>
          <div id="lista-usuarios-admin" class="lista-admin"></div>
        </div>

      </section>

      <!-- ================= ABA DISPOSITIVOS ================= -->
      <section class="aba-conteudo" id="conteudo-dispositivos" style="display:none;">
        <div class="card-config">
          <h2><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">install_mobile</span> Dispositivos vinculados</h2>
          <p style="font-size:0.85rem; color:#5c6b5d; margin-bottom:0.75rem;">
            Aparelhos que entram automaticamente em um retiro (login por dispositivo). Revogue quando um tablet trocar de retiro — ele volta a pedir a seleção no próximo acesso.
          </p>
          <div id="lista-dispositivos-admin" class="lista-admin"></div>
        </div>
      </section>

      <section class="aba-conteudo" id="conteudo-auditoria" style="display:none;">
        <div class="card-config">
          <h2><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">assignment</span> Registros de auditoria</h2>
          <p style="font-size:0.85rem; color:#5c6b5d; margin-bottom:0.75rem;">
            Acompanhe ações importantes do sistema: login, criação, edição, exclusão, sincronização e falhas.
          </p>
          <div id="lista-auditoria-admin" class="lista-admin"></div>
        </div>
      </section>

      <p class="config-msg" id="config-msg" style="display:none;"></p>

    </main>
  </div>
</div>

<script src="/public/js/configuracoes.js"></script>
<%- include('partials/footer') %>
