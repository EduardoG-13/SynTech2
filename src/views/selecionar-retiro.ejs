<%- include('partials/header') %>


<div id="device">
  <div class="header-bar">
    <button class="back-btn" onclick="window.location.href='/'">← Voltar</button>
    <h1>Olá, Capataz!</h1>
    <div class="sub">Toque no seu retiro para entrar</div>
  </div>

  <div class="content">
    <!-- Campo de Busca -->
    <div class="search-box">
      <span>🔍</span>
      <input id="searchRetiro" placeholder="Buscar retiro..." oninput="filtrarRetiros(this.value)" />
    </div>

    <!-- Lista de Retiros (gerada pelo backend via EJS forEach a partir de config/retiros.ts) -->
    <div id="lista-retiros">
      <% retiros.forEach(function(r) { %>
        <div class="card-retiro-card"
             data-nome="<%= r.nome.toLowerCase() %>"
             data-cap="<%= r.capataz.toLowerCase() %>"
             onclick="window.location.href='/tarefas?perfil=Capataz&retiro=<%= encodeURIComponent(r.nome) %>'">
          <span class="pin"><img src="../public/Icons/localizacao.ico" alt="" /></span>
          <div class="info">
            <div class="nome"><%= r.nome %></div>
            <div class="cap">Capataz: <%= r.capataz %></div>
          </div>
          <span class="arrow">›</span>
        </div>
      <% }); %>
    </div>

    <div id="lista-vazia" class="lista-vazia" style="display:none; text-align:center; color:#8A8A7C; padding:20px;">
      Nenhum retiro encontrado.
    </div>
  </div>
</div>

<script>
  // Busca client-side: filtra os cards renderizados pelo backend
  function filtrarRetiros(q) {
    q = (q || '').toLowerCase().trim();
    var visiveis = 0;
    document.querySelectorAll('#lista-retiros .retiro-card').forEach(function (c) {
      var ok = !q || c.dataset.nome.indexOf(q) >= 0 || c.dataset.cap.indexOf(q) >= 0;
      c.style.display = ok ? '' : 'none';
      if (ok) visiveis++;
    });
    document.getElementById('lista-vazia').style.display = visiveis === 0 ? 'block' : 'none';
  }
</script>

<%- include('partials/footer') %>
