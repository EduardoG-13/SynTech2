<%- include('partials/header') %>

<div id="device" class="logged">
  <%- include('partials/sidebar') %>

  <div id="app">
    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><%= perfil === 'Gerente' ? '🧑‍💼' : (perfil === 'Coordenador' ? '📋' : (perfil === 'Infraestrutura' ? '🔧' : '🤠')) %></div>
      <h1>Infraestrutura</h1>
      <div class="sub"><%= retiro %> (<%= perfil %>)</div>
    </div>

    <main class="layout" style="padding: 0;">

      <div class="filter-pills">
        <span class="pill active" data-categoria="hidraulica">Hidráulica</span>
        <span class="pill" data-categoria="cerca">Cerca</span>
        <span class="pill" data-categoria="eletrica">Elétrica</span>
      </div>

      <div class="chamados-resumo" id="chamados-resumo">

        <div class="card chamado-status-card">
          <div class="chamado-status-icon aberto">📋</div>
          <div class="chamado-status-info">
            <span class="chamado-status-label">Abertos</span>
            <span class="chamado-status-sub">Total de chamados</span>
          </div>
          <span class="chamado-status-count" id="count-abertos">0</span>
        </div>

        <div class="card chamado-status-card">
          <div class="chamado-status-icon andamento">🔧</div>
          <div class="chamado-status-info">
            <span class="chamado-status-label">Em andamento</span>
            <span class="chamado-status-sub">Total de chamados</span>
          </div>
          <span class="chamado-status-count" id="count-andamento">0</span>
        </div>

        <div class="card chamado-status-card">
          <div class="chamado-status-icon fechado">✅</div>
          <div class="chamado-status-info">
            <span class="chamado-status-label">Fechados</span>
            <span class="chamado-status-sub">Histórico semanal</span>
          </div>
          <span class="chamado-status-count" id="count-fechados">0</span>
        </div>

      </div>

      <div class="chamados-lista tarefas-lista" id="chamados-lista" style="margin-top: 1rem;">

        <div class="card tarefa-card" onclick="window.location.href='/chamado/1/resolver?perfil=<%= perfil %>&retiro=<%= retiro %>'">
          <div class="bar-lateral andamento"></div>
          <div class="body">
            <div class="info">
              <span class="titulo">🚰 Vazamento no bebedouro</span>
              <span class="descricao">Hidráulica — Pasto 4</span>
              <div class="meta"><span class="retiro-tag">📅 09/06/2026</span></div>
            </div>
            <div class="status-area">
              <span class="badge andamento">Em andamento</span>
              <span class="arrow">›</span>
            </div>
          </div>
        </div>

        <div class="card tarefa-card" onclick="window.location.href='/chamado/2/resolver?perfil=<%= perfil %>&retiro=<%= retiro %>'">
          <div class="bar-lateral pendente"></div>
          <div class="body">
            <div class="info">
              <span class="titulo">⚡ Cerca elétrica sem carga</span>
              <span class="descricao">Elétrica — divisa norte</span>
              <div class="meta"><span class="retiro-tag">📅 08/06/2026</span></div>
            </div>
            <div class="status-area">
              <span class="badge pendente">Aberto</span>
              <span class="arrow">›</span>
            </div>
          </div>
        </div>

      </div>

      <% if (perfil !== 'Infraestrutura') { %>
        <!-- Só Capataz e Gerente ABREM chamados. A Infra apenas recebe e executa. -->
        <button class="btn btn-primario" id="btn-nova-os-infra" style="width: 100%; margin-top: 1rem;" onclick="window.location.href='/novo-chamado?perfil=<%= perfil %>&retiro=<%= retiro %>'">
          ➕ Abrir Chamado de Infraestrutura
        </button>
      <% } %>

    </main>

  </div>
</div>

<%- include('partials/footer') %>
