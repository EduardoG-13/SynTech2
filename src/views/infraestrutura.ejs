<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/infraestrutura.css" />
<link rel="stylesheet" href="/public/css/tarefas.css" />

<div id="device" class="logged">
  <%- include('partials/sidebar') %>

  <div id="app">
    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><img src="/public/Icons/<%= perfil === 'Gerente' ? 'gerente' : (perfil === 'Coordenador' ? 'coordenador' : (perfil === 'Infraestrutura' ? 'infra' : 'capataz')) %>.ico" alt="<%= perfil %>" style="width:32px;height:32px;object-fit:contain;" /></div>
      <h1>Infraestrutura</h1>
      <div class="sub"><%= typeof nome !== 'undefined' ? nome : '' %> · <%= perfil %></div>
    </div>

    <main class="infra-main">

      <div class="chamados-resumo" id="chamados-resumo">

        <div class="card chamado-status-card">
          <div class="chamado-status-icon aberto"><img src="/public/Icons/pendente.ico" alt="" style="width:32px;height:32px;object-fit:contain;" /></div>
          <div class="chamado-status-info">
            <span class="chamado-status-label">Abertos</span>
            <span class="chamado-status-sub">Total de chamados</span>
          </div>
          <span class="chamado-status-count" id="count-abertos">0</span>
        </div>

        <div class="card chamado-status-card">
          <div class="chamado-status-icon andamento"><img src="/public/Icons/andamento.ico" alt="" style="width:32px;height:32px;object-fit:contain;" /></div>
          <div class="chamado-status-info">
            <span class="chamado-status-label">Em andamento</span>
            <span class="chamado-status-sub">Total de chamados</span>
          </div>
          <span class="chamado-status-count" id="count-andamento">0</span>
        </div>

        <div class="card chamado-status-card">
          <div class="chamado-status-icon fechado"><img src="/public/Icons/concluido.ico" alt="" style="width:32px;height:32px;object-fit:contain;" /></div>
          <div class="chamado-status-info">
            <span class="chamado-status-label">Fechados</span>
            <span class="chamado-status-sub">Histórico semanal</span>
          </div>
          <span class="chamado-status-count" id="count-fechados">0</span>
        </div>

      </div>

      <div class="chamados-lista tarefas-lista" id="chamados-lista" style="margin-top: 1rem;">
        <p style="text-align:center; color:#8A8A7C; padding:1rem;">Carregando chamados...</p>
      </div>

      <% if (perfil !== 'Infraestrutura') { %>
        <!-- Só Capataz e Gerente ABREM chamados. A Infra apenas recebe e executa. -->
        <button class="btn btn-primario" id="btn-nova-os-infra" style="width: 100%; margin-top: 1rem;" onclick="window.location.href='/novo-chamado?perfil=<%= perfil %>&retiro=<%= retiro %>'">
          <img class="label-ico" src="/public/Icons/infra.ico" alt="" /> Abrir Chamado de Infraestrutura
        </button>
      <% } %>

    </main>

  </div>
</div>

<script>
  (function() {
    var PERFIL = '<%= perfil %>';
    var RETIRO = '<%= retiro %>';
    var cont = document.getElementById('chamados-lista');

    fetch('/api/chamados', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var chamados = (data && data.chamados) || [];
        var counts = { ABERTO: 0, EM_ANDAMENTO: 0, RESOLVIDO: 0 };
        chamados.forEach(function(c) { if (counts[c.status] !== undefined) counts[c.status]++; });

        var elAb = document.getElementById('count-abertos');
        var elAn = document.getElementById('count-andamento');
        var elFe = document.getElementById('count-fechados');
        if (elAb) elAb.textContent = counts.ABERTO;
        if (elAn) elAn.textContent = counts.EM_ANDAMENTO;
        if (elFe) elFe.textContent = counts.RESOLVIDO;

        if (!chamados.length) {
          cont.innerHTML = '<p style="text-align:center; color:#8A8A7C; padding:1.5rem;">📭 Nenhum chamado registrado ainda.</p>';
          return;
        }

        var ICOS = { hidraulica: 'hidraulica', eletrica: 'eletrica', cerca: 'cerca', bebedouro: 'bebedouro' };
        cont.innerHTML = chamados.map(function(c) {
          var ico = ICOS[c.tipo] || 'alerta';
          var statusClasse = c.status === 'RESOLVIDO' ? 'concluida' : (c.status === 'EM_ANDAMENTO' ? 'andamento' : 'pendente');
          var statusLabel = c.status === 'RESOLVIDO' ? 'Resolvido' : (c.status === 'EM_ANDAMENTO' ? 'Em andamento' : 'Aberto');
          var data = (c.criado_em || '').slice(0, 10);
          return '<div class="card tarefa-card" onclick="window.location.href=\'/chamado/' + c.id + '/resolver\'">' +
            '<div class="bar-lateral ' + statusClasse + '"></div>' +
            '<div class="body">' +
              '<div class="info">' +
                '<span class="titulo"><img class="label-ico" src="/public/Icons/' + ico + '.ico" alt="" /> ' + (c.descricao || '').slice(0, 50) + '</span>' +
                '<span class="descricao">' + (c.tipo || '').toUpperCase() + '</span>' +
                '<div class="meta"><span class="retiro-tag">📅 ' + data + '</span></div>' +
              '</div>' +
              '<div class="status-area">' +
                '<span class="badge ' + statusClasse + '">' + statusLabel + '</span>' +
                '<span class="arrow">›</span>' +
              '</div>' +
            '</div>' +
          '</div>';
        }).join('');
      })
      .catch(function() {
        cont.innerHTML = '<p style="color:#D32F2F; text-align:center;">Erro ao carregar chamados.</p>';
      });
  })();
</script>

<%- include('partials/footer') %>
