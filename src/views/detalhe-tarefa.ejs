<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/tarefas.css" />

<div id="device" class="logged">

  <%- include('partials/sidebar') %>

  <div id="app">

    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><span class="material-symbols-rounded ui-icon" aria-hidden="true">engineering</span></div>
      <h1>Detalhe da Tarefa</h1>
      <div class="sub"><%= typeof nome !== 'undefined' ? nome : '' %> · <%= perfil %> · <%= retiro %></div>
    </div>

    <main class="detalhe-main">

      <button class="btn-voltar" onclick="window.history.back()"><span class="material-symbols-rounded ui-icon back-ico" aria-hidden="true">arrow_back</span> Voltar</button>

      <!-- Cabeçalho: tipo + status -->
      <div class="card detalhe-cabecalho">
        <h2 id="t-titulo">Carregando...</h2>
        <span class="badge pendente" id="t-status">Carregando</span>
      </div>

      <!-- Dados principais -->
      <div class="card detalhe-bloco">
        <h3><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">assignment</span> Dados da tarefa</h3>
        <div class="dados-grid">
          <div class="dado"><span class="dado-label"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">swap_horiz</span> Tipo</span><span class="dado-valor" id="t-tipo">—</span></div>
          <div class="dado"><span class="dado-label"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">location_on</span> Retiro</span><span class="dado-valor" id="t-retiro">—</span></div>
          <div class="dado"><span class="dado-label"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">calendar_month</span> Data de execução</span><span class="dado-valor" id="t-data">—</span></div>
          <div class="dado"><span class="dado-label"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">warning</span> Prioridade</span><span class="dado-valor" id="t-prioridade">—</span></div>
          <div class="dado"><span class="dado-label"><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">manage_accounts</span> Criada por</span><span class="dado-valor" id="t-gerente">—</span></div>
        </div>
      </div>

      <!-- Instruções do gerente -->
      <div class="card detalhe-bloco">
        <h3><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">edit</span> Instruções</h3>
        <p id="t-observacoes">—</p>
      </div>

      <!-- Áudio do gerente -->
      <div class="card detalhe-bloco" id="bloco-audio">
        <h3><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">mic</span> Áudio de instrução</h3>
        <audio controls id="t-audio" style="width:100%; display:none;"></audio>
        <p class="sem-audio" id="t-sem-audio"> Sem áudio anexado.</p>
      </div>

      <!-- Foto de referência -->
      <div class="card detalhe-bloco" id="bloco-foto">
        <h3><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">photo_camera</span> Foto de referência</h3>
        <img id="t-foto" class="foto-preview" style="display:none;" />
        <p class="sem-audio" id="t-sem-foto"> Sem foto de referência.</p>
        <p class="ajuda-detalhe" style="margin-top:0.5rem; color:#A64B00;" id="aviso-foto-extra"> Você ainda precisará tirar a foto na execução, conforme o tipo da tarefa.</p>
      </div>

      <!-- Botão Iniciar -->
      <button class="btn-enviar-detalhe" id="btn-iniciar" style="display:none;">
        <span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">play_arrow</span> Iniciar tarefa
      </button>
      <p id="t-msg" class="form-msg" style="display:none;"></p>

      <!-- Resultado se já concluída -->
      <div class="card detalhe-bloco" id="bloco-concluida" style="display:none;">
        <h3><span class="material-symbols-rounded ui-icon label-ico" aria-hidden="true">check_circle</span> Tarefa concluída</h3>
        <p>Esta tarefa já foi executada por você em <strong id="t-concluida-em">—</strong>.</p>
      </div>

    </main>

  </div>
</div>

<script>
  var TAREFA_ID = '<%= typeof tarefaId !== "undefined" ? tarefaId : "" %>';
  var TAREFA = null;
  var ROTULOS_OP = {
    nascimento:    'Nascimento',
    obito:         'Morte',
    transferencia: 'Transferência',
    compravenda:   'Compra / Venda',
    evolucao:      'Evolução',
    manejo:        'Manejo'
  };

  document.addEventListener('DOMContentLoaded', function() {
    if (!TAREFA_ID) { document.getElementById('t-titulo').textContent = 'ID inválido'; return; }
    carregar();

    document.getElementById('btn-iniciar').addEventListener('click', function() {
      // Vai pra Nova OS com query string da tarefa — lá ela vai pré-preencher
      window.location.href = '/nova-os?tarefa=' + encodeURIComponent(TAREFA_ID);
    });
  });

  function setText(id, v) {
    var el = document.getElementById(id);
    if (el) el.textContent = (v === null || v === undefined || v === '') ? '—' : v;
  }

  function carregar() {
    fetch('/api/tarefas/' + encodeURIComponent(TAREFA_ID), { credentials: 'same-origin' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(t) {
        if (!t) { document.getElementById('t-titulo').textContent = 'Tarefa não encontrada'; return; }
        TAREFA = t;
        renderTarefa(t);
        // Marca como vista (uma vez)
        if (!t.vista_em) {
          fetch('/api/tarefas/' + encodeURIComponent(TAREFA_ID) + '/marcar-vista', {
            method: 'PATCH', credentials: 'same-origin'
          }).catch(function(){});
        }
      });
  }

  function renderTarefa(t) {
    setText('t-titulo', t.titulo);
    setText('t-tipo', ROTULOS_OP[t.tipo_operacao] || t.tipo_operacao || '—');
    setText('t-retiro', t.retiro_nome || t.retiro_id);
    setText('t-data', t.data_execucao);
    setText('t-prioridade', (t.prioridade || 'média').toUpperCase());
    setText('t-gerente', t.gerente_nome || '—');
    setText('t-observacoes', t.observacoes || t.descricao || '—');

    var badge = document.getElementById('t-status');
    if (t.status === 'CONCLUIDA') {
      badge.textContent = ' Concluída';
      badge.className = 'badge concluida';
      document.getElementById('bloco-concluida').style.display = 'block';
      setText('t-concluida-em', (t.concluida_em || '').replace('T', ' ').slice(0, 16));
    } else if (t.status === 'EM_ANDAMENTO') {
      badge.textContent = 'Em andamento';
      badge.className = 'badge andamento';
      document.getElementById('btn-iniciar').style.display = 'block';
    } else {
      badge.textContent = 'Pendente';
      badge.className = 'badge pendente';
      document.getElementById('btn-iniciar').style.display = 'block';
    }

    // Áudio
    if (t.audio_base64) {
      var au = document.getElementById('t-audio');
      au.src = t.audio_base64;
      au.style.display = 'block';
      document.getElementById('t-sem-audio').style.display = 'none';
    }
    // Foto
    if (t.foto_base64) {
      var img = document.getElementById('t-foto');
      var src = t.foto_base64.indexOf('data:') === 0 ? t.foto_base64 : ('data:image/jpeg;base64,' + t.foto_base64);
      img.src = src;
      img.style.display = 'block';
      document.getElementById('t-sem-foto').style.display = 'none';
    } else {
      document.getElementById('aviso-foto-extra').style.display = 'none';
    }
  }
</script>

<%- include('partials/footer') %>
