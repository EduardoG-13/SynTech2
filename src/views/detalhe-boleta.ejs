<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/tarefas.css" />

<div id="device" class="logged">

  <%- include('partials/sidebar') %>

  <div id="app">

    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><img src="/public/Icons/<%= perfil === 'Gerente' ? 'gerente' : (perfil === 'Coordenador' ? 'coordenador' : (perfil === 'Infraestrutura' ? 'infra' : 'capataz')) %>.ico" alt="<%= perfil %>" style="width:32px;height:32px;object-fit:contain;" /></div>
      <h1>Detalhe da Boleta</h1>
      <div class="sub"><%= retiro %> (<%= perfil %>)</div>
    </div>

    <main class="detalhe-main">

      <button class="btn-voltar" onclick="window.history.back()">⬅️ Voltar</button>

      <!-- Cabeçalho: tipo + status -->
      <div class="card detalhe-cabecalho">
        <h2 id="bol-tipo"><img class="label-ico" src="/public/Icons/movimentacao.ico" alt="" /> Movimentação</h2>
        <span class="badge concluida" id="bol-status">✓ Enviado</span>
      </div>

      <!-- ============ DADOS DA REQUISIÇÃO ============ -->
      <div class="card detalhe-bloco">
        <h3>📋 Dados do registro</h3>
        <div class="dados-grid">
          <div class="dado"><span class="dado-label">📍 Retiro</span><span class="dado-valor" id="bol-retiro"><%= retiro %></span></div>
          <div class="dado"><span class="dado-label">📅 Data</span><span class="dado-valor" id="bol-data">09/06/2026</span></div>
          <div class="dado"><span class="dado-label">🌾 Pasto</span><span class="dado-valor" id="bol-pasto">Pasto 12</span></div>
          <div class="dado"><span class="dado-label">👷 Capataz</span><span class="dado-valor" id="bol-capataz">Rogério</span></div>
        </div>
      </div>

      <!-- Transferência (origem/destino) -->
      <div class="card detalhe-bloco" id="bloco-transferencia">
        <h3><img class="label-ico" src="/public/Icons/movimentacao.ico" alt="" /> Transferência</h3>
        <div class="dados-grid">
          <div class="dado"><span class="dado-label">📤 Origem</span><span class="dado-valor">Acurizal</span></div>
          <div class="dado"><span class="dado-label">🎯 Destino</span><span class="dado-valor">Cristo</span></div>
          <div class="dado"><span class="dado-label">🚚 Transporte</span><span class="dado-valor">Caminhão</span></div>
          <div class="dado"><span class="dado-label">👤 Motorista</span><span class="dado-valor">João Silva</span></div>
        </div>
      </div>

      <!-- Animais (categorias e quantidades) -->
      <div class="card detalhe-bloco">
        <h3><img class="label-ico" src="/public/Icons/movimentacao.ico" alt="" /> Animais</h3>
        <table class="dados-tabela">
          <thead><tr><th>Categoria</th><th>Quantidade</th></tr></thead>
          <tbody id="bol-animais">
            <tr><td>Garrote 8 a 12 meses</td><td>30</td></tr>
            <tr><td>Garrote 13 a 24 meses</td><td>15</td></tr>
          </tbody>
          <tfoot><tr><td><strong>Total</strong></td><td><strong id="bol-total">45</strong></td></tr></tfoot>
        </table>
      </div>

      <!-- Observações (texto + áudio) -->
      <div class="card detalhe-bloco">
        <h3>📝 Observações</h3>
        <p id="bol-obs">Movimentação feita na rotina da manhã, sem intercorrências.</p>
        <div id="bol-audio-wrap">
          <p class="ajuda-detalhe"><img class="label-ico" src="/public/Icons/grava_audio.ico" alt="" /> Áudio gravado pelo capataz:</p>
          <audio controls id="bol-audio" style="width:100%;"></audio>
          <p class="sem-audio" id="bol-sem-audio">🔇 Sem áudio anexado.</p>
        </div>
      </div>

      <!-- Foto -->
      <div class="card detalhe-bloco" id="bloco-foto">
        <h3><img class="label-ico" src="/public/Icons/tira_foto.ico" alt="" /> Foto anexada</h3>
        <img id="bol-foto" class="foto-preview" alt="Foto da boleta" style="display:none;" />
        <p class="sem-audio" id="bol-sem-foto">📭 Nenhuma foto anexada.</p>
      </div>

      <!-- ============ DADOS DA CONCLUSÃO / VALIDAÇÃO ============ -->
      <div class="card detalhe-bloco bloco-conclusao">
        <h3>✅ Status de validação</h3>
        <div class="dados-grid">
          <div class="dado"><span class="dado-label">Situação</span><span class="dado-valor" id="bol-validacao">Aguardando validação do coordenador</span></div>
          <div class="dado"><span class="dado-label">Sincronização</span><span class="dado-valor" id="bol-sync">Enviado para a nuvem</span></div>
        </div>
      </div>

      <!-- Ações por perfil -->
      <% if (perfil === 'Capataz') { %>
        <button class="btn-enviar-detalhe" id="btn-editar">
          ✏️ Editar boleta
        </button>
        <p id="bloqueio-edicao" style="display:none; text-align:center; color:#A64B00; font-size:0.85rem; margin-top:0.5rem;">
          🔒 Boleta com mais de 30 dias — não pode mais ser editada (ciclo do Coordenador já fechado).
        </p>
      <% } else if (perfil === 'Coordenador') { %>
        <button class="btn-enviar-detalhe" id="btn-validar">✅ Validar e aprovar</button>
        <button class="btn-baixar" id="btn-baixar">⬇️ Baixar boleta (CSV)</button>
      <% } %>

      <p class="form-msg" id="bol-msg" style="display:none;"></p>

    </main>

  </div>
</div>

<script>
  var PERFIL = '<%= perfil %>';
  var BOLETA_ID = '<%= typeof boletaId !== "undefined" ? boletaId : "" %>';

  document.addEventListener('DOMContentLoaded', function() {
    // Carrega dados reais do localStorage (escritos pela /nova-os ao registrar)
    carregarBoleta();

    // Botão Editar (Capataz): só permitido dentro da janela de 30 dias
    var btnEditar = document.getElementById('btn-editar');
    var bloqueio = document.getElementById('bloqueio-edicao');
    if (btnEditar) {
      verificarJanelaEdicao(btnEditar, bloqueio);
      btnEditar.addEventListener('click', function() {
        window.location.href = '/nova-os?edit=' + encodeURIComponent(BOLETA_ID);
      });
    }

    var btnValidar = document.getElementById('btn-validar');
    if (btnValidar) {
      btnValidar.addEventListener('click', function() {
        // TODO: PUT /api/eventos-zootecnicos/:id/validar (integração pendente)
        mostrarMsg('✅ Boleta validada! (integração com API pendente)', 'sucesso');
      });
    }
    var btnBaixar = document.getElementById('btn-baixar');
    if (btnBaixar) {
      btnBaixar.addEventListener('click', function() {
        mostrarMsg('⬇️ Exportação será ligada ao endpoint /api/exportacao.', 'sucesso');
      });
    }
  });

  function mostrarMsg(texto, tipo) {
    var el = document.getElementById('bol-msg');
    el.textContent = texto;
    el.className = 'form-msg ' + tipo;
    el.style.display = 'block';
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  // Janela de edição: até 30 dias após criação. Depois disso o Coordenador já fechou.
  function verificarJanelaEdicao(btnEditar, bloqueio) {
    var lista = [];
    try { lista = JSON.parse(localStorage.getItem('brpec_registros') || '[]'); } catch(e){}
    var reg = lista.find(function(r) { return String(r.id) === String(BOLETA_ID); });
    if (!reg || !reg.criadoEm) return; // sem data, deixa editar
    var diff = Date.now() - new Date(reg.criadoEm).getTime();
    var dias = diff / (1000 * 60 * 60 * 24);
    if (dias > 30) {
      btnEditar.style.display = 'none';
      if (bloqueio) bloqueio.style.display = 'block';
    }
  }

  function carregarBoleta() {
    var lista = [];
    try { lista = JSON.parse(localStorage.getItem('brpec_registros') || '[]'); } catch(e){}
    var reg = lista.find(function(r) { return String(r.id) === String(BOLETA_ID); });

    // Fallback: se id não bateu, usa o último registrado (vindo da tela de sucesso)
    if (!reg) {
      try { reg = JSON.parse(localStorage.getItem('brpec_ultimo_registro') || 'null'); } catch(e){}
    }

    if (!reg) {
      document.getElementById('bol-tipo').textContent = 'Boleta não encontrada';
      document.getElementById('bol-status').textContent = '—';
      return;
    }

    var RANKS = {
      'nascimento': { ico: 'nascimento', label: 'Nascimento' },
      'obito': { ico: 'obto', label: 'Óbito' },
      'transferencia': { ico: 'movimentacao', label: 'Transferência' },
      'compravenda': { ico: 'movimentacao', label: 'Compra/Venda' },
      'evolucao': { ico: 'movimentacao', label: 'Evolução' },
      'manejo': { ico: 'tarefas', label: 'Manejo' }
    };
    var meta = RANKS[reg.operacao] || { ico: 'tarefas', label: reg.operacao || 'Boleta' };

    document.getElementById('bol-tipo').innerHTML =
      '<img class="label-ico" src="/public/Icons/' + meta.ico + '.ico" alt="" /> ' + meta.label;

    if (reg.retiro || reg.retiro_origem)
      document.getElementById('bol-retiro').textContent = reg.retiro || reg.retiro_origem;
    if (reg.data) document.getElementById('bol-data').textContent = reg.data;
    if (reg.pasto) document.getElementById('bol-pasto').textContent = reg.pasto;

    // Mostra bloco de transferência só quando aplica
    var blocoTransf = document.getElementById('bloco-transferencia');
    if (reg.operacao !== 'transferencia') blocoTransf.style.display = 'none';

    // Animais
    if (reg.animais && reg.animais.length) {
      var tbody = document.getElementById('bol-animais');
      tbody.innerHTML = reg.animais.map(function(a){
        return '<tr><td>' + a.categoria + '</td><td>' + a.quantidade + '</td></tr>';
      }).join('');
      var total = reg.animais.reduce(function(s,a){return s+(parseInt(a.quantidade)||0);},0);
      document.getElementById('bol-total').textContent = total;
    }

    // Observações texto + áudio
    if (reg.observacoes) document.getElementById('bol-obs').textContent = reg.observacoes;
    if (reg.observacoes_audio) {
      var au = document.getElementById('bol-audio');
      au.src = reg.observacoes_audio;
      au.style.display = 'block';
      document.getElementById('bol-sem-audio').style.display = 'none';
    } else {
      document.getElementById('bol-audio').style.display = 'none';
      document.getElementById('bol-sem-audio').style.display = 'block';
    }

    document.getElementById('bol-sem-foto').style.display = reg.tem_foto ? 'none' : 'block';
  }
</script>

<%- include('partials/footer') %>
