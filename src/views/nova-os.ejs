<%- include('partials/header') %>
<link rel="stylesheet" href="/public/css/nova-os.css" />

<div id="device" class="logged">
  <%- include('partials/sidebar') %>

  <div id="app">
    <div class="header-bar" style="margin-top: 0; margin-bottom: 2rem;">
      <div class="user-avatar"><img src="/public/Icons/<%= perfil === 'Gerente' ? 'gerente' : (perfil === 'Coordenador' ? 'coordenador' : (perfil === 'Infraestrutura' ? 'infra' : 'capataz')) %>.ico" alt="<%= perfil %>" style="width:32px;height:32px;object-fit:contain;" /></div>
      <h1>Nova Boleta</h1>
      <div class="sub"><%= typeof nome !== 'undefined' ? nome : '' %> · <%= perfil %> · <%= retiro %></div>
    </div>

    <main class="form-main">

      <button class="btn-voltar" onclick="window.history.back()">⬅️ Voltar</button>

      <form id="form-nova-os">

        <!-- 1. Operação (sempre visível) — grid de cards com ícone -->
        <div class="card campo">
          <label><img class="label-ico" src="/public/Icons/tarefas.ico" alt="" /> O que você quer registrar?</label>
          <div class="operacao-grid" id="operacao-grid"></div>
          <input type="hidden" id="os-operacao" required />
        </div>

        <!-- ===================== MOVIMENTAÇÃO ===================== -->
        <div class="card campo dinamico" data-op="transferencia">
          <label><img class="label-ico" src="/public/Icons/bussola_direcao_guia.ico" alt="" /> Direção</label>
          <div class="toggle-pills">
            <button type="button" class="pill active" data-tipo="envio"><img class="label-ico" src="/public/Icons/envio_animais_caixa.ico" alt="" /> Saindo</button>
            <button type="button" class="pill" data-tipo="recebimento"><img class="label-ico" src="/public/Icons/entrada_animais_recebimento_compra.ico" alt="" /> Entrando</button>
          </div>
        </div>

        <div class="card campo dinamico" data-op="transferencia">
          <label for="os-retiro-origem"><img class="label-ico" src="/public/Icons/localizacao.ico" alt="" /> De onde sai</label>
          <select id="os-retiro-origem"></select>
        </div>

        <div class="card campo dinamico" data-op="transferencia">
          <label for="os-retiro-destino"><img class="label-ico" src="/public/Icons/destido.ico" alt="" /> Para onde vai</label>
          <select id="os-retiro-destino"></select>
        </div>

        <div class="card campo dinamico" data-op="transferencia">
          <label><img class="label-ico" src="/public/Icons/caminhao_transporte_gado.ico" alt="" /> Transporte</label>
          <div class="toggle-pills">
            <button type="button" class="pill active" data-transporte="rodoviario"><img class="label-ico" src="/public/Icons/caminhao_transporte_gado.ico" alt="" /> Caminhão</button>
            <button type="button" class="pill" data-transporte="comitiva"><img class="label-ico" src="/public/Icons/comitiva_peao_a_cavalo.ico" alt="" /> Comitiva</button>
          </div>
        </div>

        <!-- ===================== RETIRO (demais operações) ===================== -->
        <div class="card campo dinamico" data-op="nascimento obito compravenda evolucao manejo">
          <label for="os-retiro"><img class="label-ico" src="/public/Icons/localizacao.ico" alt="" /> Retiro</label>
          <select id="os-retiro"></select>
        </div>

        <!-- ===================== Nº DO PASTO + DATA ===================== -->
        <div class="card campo dinamico" data-op="nascimento obito transferencia compravenda evolucao">
          <div class="dois-campos">
            <div>
              <label for="os-pasto"><img class="label-ico" src="/public/Icons/Pasto.ico" alt="" /> Pasto <span class="opcional-txt">(opcional)</span></label>
              <input type="text" id="os-pasto" placeholder="Ex: 12" />
            </div>
            <div>
              <label for="os-data"><img class="label-ico" src="/public/Icons/calendario_pagina_agenda.ico" alt="" /> Data</label>
              <input type="date" id="os-data" />
            </div>
          </div>
        </div>

        <!-- ===================== CATEGORIAS + QUANTIDADES (repetível) ===================== -->
        <div class="card campo dinamico" data-op="nascimento obito transferencia compravenda">
          <label><img class="label-ico" src="/public/Icons/movimentacao.ico" alt="" /> Animais</label>
          <div id="linhas-categoria"></div>
          <button type="button" class="btn-add" id="btn-add-categoria">➕ Adicionar categoria</button>
          <div class="total-linha">
            <span><img class="label-ico" src="/public/Icons/abaco_calculo_total.ico" alt="" /> Total:</span>
            <strong id="total-animais">0</strong>
          </div>
        </div>

        <!-- ===================== MUDANÇA DE IDADE (de → para) ===================== -->
        <div class="card campo dinamico" data-op="evolucao">
          <label><img class="label-ico" src="/public/Icons/evolucao.ico" alt="" /> Mudança de idade</label>
          <p class="ajuda">Quando o animal cresce e troca de categoria (ex: bezerro → garrote).</p>
          <div id="linhas-evolucao"></div>
          <button type="button" class="btn-add" id="btn-add-evolucao">➕ Adicionar mudança</button>
        </div>

        <!-- ===================== NASCIMENTO: raça ===================== -->
        <div class="card campo dinamico" data-op="nascimento">
          <label for="os-raca"><img class="label-ico" src="/public/Icons/nascimento.ico" alt="" /> Raça</label>
          <input type="text" id="os-raca" placeholder="Ex: Nelore" />
        </div>

        <!-- ===================== MORTE: ID do animal + causa ===================== -->
        <div class="card campo dinamico destaque-obito" data-op="obito">
          <label for="os-brinco"><img class="label-ico" src="/public/Icons/Brinco.ico" alt="" /> Brinco</label>
          <input type="text" id="os-brinco" placeholder="Ex: 4471" />
        </div>

        <div class="card campo dinamico destaque-obito" data-op="obito">
          <label for="os-causa"><img class="label-ico" src="/public/Icons/obto.ico" alt="" /> Causa</label>
          <select id="os-causa"></select>
        </div>

        <!-- ===================== COMPRA/VENDA ===================== -->
        <div class="card campo dinamico" data-op="compravenda">
          <label><img class="label-ico" src="/public/Icons/cedula_dinheiro_bovino.ico" alt="" /> Tipo de negócio</label>
          <div class="toggle-pills">
            <button type="button" class="pill active" data-negocio="compra"><img class="label-ico" src="/public/Icons/carrinho_compras_gado.ico" alt="" /> Compra</button>
            <button type="button" class="pill" data-negocio="venda"><img class="label-ico" src="/public/Icons/aperto_maos_acordo.ico" alt="" /> Venda</button>
          </div>
        </div>

        <div class="card campo dinamico" data-op="compravenda">
          <label for="os-valor"><img class="label-ico" src="/public/Icons/cedula_dinheiro_bovino.ico" alt="" /> Valor (R$)</label>
          <input type="number" id="os-valor" min="0" step="0.01" placeholder="0,00" />
        </div>

        <!-- ===================== MANEJO GERAL ===================== -->
        <div class="card campo dinamico" data-op="manejo">
          <label for="os-titulo"><img class="label-ico" src="/public/Icons/tarefas.ico" alt="" /> Título</label>
          <input type="text" id="os-titulo" placeholder="Ex: Vacinação" />
        </div>

        <!-- ===================== OBSERVAÇÕES (texto OU áudio) ===================== -->
        <div class="card campo dinamico" data-op="nascimento obito transferencia compravenda evolucao manejo">
          <label for="os-observacoes"><img class="label-ico" src="/public/Icons/editar.ico" alt="" /> Observações</label>
          <textarea id="os-observacoes" rows="3" placeholder="Escreva ou grave um áudio (opcional)"></textarea>

          <div class="audio-rec">
            <button type="button" class="btn-audio" id="btn-gravar-audio">
              <img class="label-ico" src="/public/Icons/grava_audio.ico" alt="" />
              <span id="audio-btn-txt">Gravar áudio</span>
            </button>
            <audio id="audio-preview" controls style="display:none; width:100%; margin-top:0.5rem;"></audio>
            <button type="button" class="btn-audio-remover" id="btn-remover-audio" style="display:none;">🗑️ Apagar áudio</button>
          </div>
        </div>

        <!-- ===================== FOTO (óbito = obrigatória) ===================== -->
        <div class="card campo dinamico destaque-obito" data-op="obito">
          <label><img class="label-ico" src="/public/Icons/tira_foto.ico" alt="" /> Foto da carcaça <span class="obrigatorio">* obrigatória</span></label>
          <div class="upload-foto">
            <label for="os-foto" class="upload-label">
              <img class="upload-icon-img" src="/public/Icons/tira_foto.ico" alt="" />
              <span id="foto-label-txt">📷 Tirar foto ou escolher do celular</span>
            </label>
            <input type="file" id="os-foto" accept="image/*" />
          </div>
        </div>

        <!-- ===================== FOTO (manejo = opcional) ===================== -->
        <div class="card campo dinamico" data-op="manejo">
          <label><img class="label-ico" src="/public/Icons/tira_foto.ico" alt="" /> Foto da execução <span class="opcional-txt">(opcional)</span></label>
          <div class="upload-foto">
            <label for="os-foto-manejo" class="upload-label">
              <img class="upload-icon-img" src="/public/Icons/tira_foto.ico" alt="" />
              <span id="foto-manejo-txt">📷 Tirar foto ou escolher do celular</span>
            </label>
            <input type="file" id="os-foto-manejo" accept="image/*" />
          </div>
        </div>

        <button type="submit" class="btn-enviar" id="btn-enviar" disabled>
          <img class="btn-ico" src="/public/Icons/concluido.ico" alt="" /> Registrar Boleta
        </button>

        <p class="form-msg" id="form-msg" style="display:none;"></p>

      </form>

    </main>
  </div>
</div>

<script>
  var RETIRO_LOGADO = '<%= retiro %>';
  var PERFIL = '<%= perfil %>';
  var TIPO_TRANSF = 'envio';
  var TIPO_NEGOCIO = 'compra';
  var TIPO_TRANSPORTE = 'rodoviario';
  var CATEGORIAS = [];
  var CATEGORIAS_NASCIMENTO = [];

  document.addEventListener('DOMContentLoaded', function() {
    var hoje = new Date().toISOString().split('T')[0];
    var inputData = document.getElementById('os-data');
    if (inputData) inputData.value = hoje;

    carregarDados();
    configurarOperacao();
    configurarToggles();
    configurarFotoLabel();
    configurarAudio();

    document.getElementById('btn-add-categoria').addEventListener('click', function() { addLinhaCategoria(); });
    document.getElementById('btn-add-evolucao').addEventListener('click', function() { addLinhaEvolucao(); });

    // Modo edição: ?edit=ID busca o registro salvo localmente e preenche o formulário
    var params = new URLSearchParams(window.location.search);
    var editId = params.get('edit');
    if (editId) {
      // Espera um pouco pra carregarDados() popular os selects antes
      setTimeout(function() { preencherParaEdicao(editId); }, 600);
    }
  });

  function preencherParaEdicao(id) {
    fetch('/api/boletas/' + encodeURIComponent(id), { credentials: 'same-origin' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(reg) {
        if (!reg) {
          mostrarMsg('⚠️ Boleta não encontrada para edição.', 'erro');
          return;
        }
        if (reg.criadoEm) {
          var dias = (Date.now() - new Date(reg.criadoEm).getTime()) / (1000 * 60 * 60 * 24);
          if (dias > 30) {
            mostrarMsg('🔒 Esta boleta tem mais de 30 dias e não pode mais ser editada.', 'erro');
            setTimeout(function() { window.location.href = '/boleta/' + id; }, 2000);
            return;
          }
        }
        if (reg.aprovada) {
          mostrarMsg('🔒 Boleta já aprovada pelo Coordenador, não pode mais ser editada.', 'erro');
          setTimeout(function() { window.location.href = '/boleta/' + id; }, 2000);
          return;
        }
        preencherCamposEdicao(reg);
      })
      .catch(function() { mostrarMsg('❌ Erro ao carregar boleta.', 'erro'); });
  }

  function preencherCamposEdicao(reg) {

    // Operação dispara o show dos campos certos
    var selOp = document.getElementById('os-operacao');
    selOp.value = reg.operacao || '';
    selOp.dispatchEvent(new Event('change'));

    // Preenche campos simples
    setVal('os-data', reg.data);
    setVal('os-retiro', reg.retiro);
    setVal('os-retiro-origem', reg.retiro_origem);
    setVal('os-retiro-destino', reg.retiro_destino);
    setVal('os-pasto', reg.pasto);
    setVal('os-raca', reg.raca);
    setVal('os-brinco', reg.brinco);
    setVal('os-causa', reg.causa);
    setVal('os-valor', reg.valor);
    setVal('os-titulo', reg.titulo);
    setVal('os-motorista', reg.motorista);
    setVal('os-rgcpf', reg.rgcpf);
    setVal('os-placa', reg.placa);
    setVal('os-observacoes', reg.observacoes);

    // Categorias/quantidades repetíveis
    if (reg.animais && reg.animais.length) {
      var cont = document.getElementById('linhas-categoria');
      cont.innerHTML = ''; // limpa o que addLinhaCategoria criou
      reg.animais.forEach(function(a) {
        addLinhaCategoria();
        var ultima = cont.lastElementChild;
        ultima.querySelector('.cat-sel').value = a.categoria;
        ultima.querySelector('.cat-qtd').value = a.quantidade;
      });
      atualizarTotal();
    }

    // Áudio recuperado
    if (reg.observacoes_audio) {
      audioBase64 = reg.observacoes_audio;
      var preview = document.getElementById('audio-preview');
      if (preview) { preview.src = audioBase64; preview.style.display = 'block'; }
      var btnRem = document.getElementById('btn-remover-audio');
      if (btnRem) btnRem.style.display = 'inline-block';
    }

    // Toggles (envio/recebimento, compra/venda, transporte)
    if (reg.tipo) {
      document.querySelectorAll('.toggle-pills .pill').forEach(function(p) {
        if (p.dataset.tipo === reg.tipo || p.dataset.negocio === reg.tipo) p.click();
      });
    }
    if (reg.transporte) {
      document.querySelectorAll('.toggle-pills .pill').forEach(function(p) {
        if (p.dataset.transporte === reg.transporte) p.click();
      });
    }

    // Marca o título da página como "Editando"
    var h1 = document.querySelector('.header-bar h1');
    if (h1) h1.textContent = 'Editar Boleta';
    mostrarMsg('✏️ Modo edição — altere o que precisar e salve.', 'sucesso');
  }

  function setVal(id, valor) {
    var el = document.getElementById(id);
    if (el && valor != null) el.value = valor;
  }

  // ===== Gravação de áudio para observações (capataz que não escreve) =====
  var mediaRecorder = null;
  var audioChunks = [];
  var audioBase64 = '';
  var gravando = false;

  function configurarAudio() {
    var btn = document.getElementById('btn-gravar-audio');
    var btnRemover = document.getElementById('btn-remover-audio');
    if (!btn) return;

    btn.addEventListener('click', function() {
      if (!gravando) iniciarGravacao(); else pararGravacao();
    });
    btnRemover.addEventListener('click', function() {
      audioBase64 = '';
      var preview = document.getElementById('audio-preview');
      preview.src = '';
      preview.style.display = 'none';
      btnRemover.style.display = 'none';
    });
  }

  function iniciarGravacao() {
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      mostrarMsg('🎙️ Seu navegador não permite gravar áudio.', 'erro');
      return;
    }
    navigator.mediaDevices.getUserMedia({ audio: true }).then(function(stream) {
      mediaRecorder = new MediaRecorder(stream);
      audioChunks = [];
      mediaRecorder.ondataavailable = function(e) { audioChunks.push(e.data); };
      mediaRecorder.onstop = function() {
        var blob = new Blob(audioChunks, { type: 'audio/webm' });
        var reader = new FileReader();
        reader.onloadend = function() {
          audioBase64 = reader.result; // data URL base64
          var preview = document.getElementById('audio-preview');
          preview.src = audioBase64;
          preview.style.display = 'block';
          document.getElementById('btn-remover-audio').style.display = 'inline-block';
        };
        reader.readAsDataURL(blob);
        stream.getTracks().forEach(function(t) { t.stop(); });
      };
      mediaRecorder.start();
      gravando = true;
      document.getElementById('audio-btn-txt').textContent = '⏹️ Parar gravação';
      document.getElementById('btn-gravar-audio').classList.add('gravando');
    }).catch(function() {
      mostrarMsg('🎙️ Permissão de microfone negada.', 'erro');
    });
  }

  function pararGravacao() {
    if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
    gravando = false;
    document.getElementById('audio-btn-txt').textContent = 'Gravar novamente';
    document.getElementById('btn-gravar-audio').classList.remove('gravando');
  }

  function optsCategorias(lista) {
    var fonte = lista || CATEGORIAS;
    return '<option value="">Categoria...</option>' +
      fonte.map(function(c) { return '<option value="' + c + '">' + c + '</option>'; }).join('');
  }

  // Adiciona uma linha de categoria + quantidade
  function addLinhaCategoria() {
    // Nascimento: só bezerro/bezerra
    var op = (document.getElementById('os-operacao') || {}).value;
    var lista = (op === 'nascimento' && CATEGORIAS_NASCIMENTO.length) ? CATEGORIAS_NASCIMENTO : CATEGORIAS;
    var div = document.createElement('div');
    div.className = 'linha-cat';
    div.innerHTML =
      '<select class="cat-sel">' + optsCategorias(lista) + '</select>' +
      '<input type="number" class="cat-qtd" min="1" placeholder="Qtd" />' +
      '<button type="button" class="btn-remover">🗑️</button>';
    div.querySelector('.btn-remover').addEventListener('click', function() {
      div.remove();
      atualizarTotal();
    });
    var qtd = div.querySelector('.cat-qtd');
    qtd.addEventListener('input', function() {
      sanitizarQtd(qtd);
      atualizarTotal();
    });
    document.getElementById('linhas-categoria').appendChild(div);
  }

  // Impede números negativos ou zero no campo de quantidade
  function sanitizarQtd(input) {
    var v = parseInt(input.value);
    if (isNaN(v) || v < 1) input.value = input.value === '' ? '' : '1';
  }

  // Adiciona uma linha de evolução (origem → destino)
  function addLinhaEvolucao() {
    var div = document.createElement('div');
    div.className = 'linha-evo';
    div.innerHTML =
      '<select class="evo-origem">' + optsCategorias() + '</select>' +
      '<span class="seta-evo">➡️</span>' +
      '<select class="evo-destino">' + optsCategorias() + '</select>' +
      '<input type="number" class="evo-qtd" min="1" placeholder="Qtd" />' +
      '<button type="button" class="btn-remover">🗑️</button>';
    div.querySelector('.btn-remover').addEventListener('click', function() { div.remove(); });
    var eqtd = div.querySelector('.evo-qtd');
    eqtd.addEventListener('input', function() { sanitizarQtd(eqtd); });
    document.getElementById('linhas-evolucao').appendChild(div);
  }

  function atualizarTotal() {
    var total = 0;
    document.querySelectorAll('#linhas-categoria .cat-qtd').forEach(function(inp) {
      total += Math.max(0, parseInt(inp.value) || 0);
    });
    document.getElementById('total-animais').textContent = total;
  }

  // Mapeia cada operação ao seu ícone temático
  var ICO_OPERACAO = {
    nascimento:    'nascimento',
    obito:         'obto',
    transferencia: 'movimentacao',
    compravenda:   'cedula_dinheiro_bovino',
    evolucao:      'evolucao',
    manejo:        'tarefas'
  };

  function carregarDados() {
    fetch('/api/dados/form-nova-os')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var grid = document.getElementById('operacao-grid');
        if (grid) {
          grid.innerHTML = d.operacoes.map(function(o) {
            var ico = ICO_OPERACAO[o.valor] || 'tarefas';
            return '<button type="button" class="op-card" data-op="' + o.valor + '">' +
              '<img class="op-card-ico" src="/public/Icons/' + ico + '.ico" alt="" />' +
              '<span class="op-card-label">' + o.label + '</span>' +
            '</button>';
          }).join('');
          grid.querySelectorAll('.op-card').forEach(function(card) {
            card.addEventListener('click', function() {
              grid.querySelectorAll('.op-card').forEach(function(c) { c.classList.remove('active'); });
              card.classList.add('active');
              var inp = document.getElementById('os-operacao');
              inp.value = card.dataset.op;
              inp.dispatchEvent(new Event('change'));
            });
          });
        }

        var optsRetiro = d.retiros.map(function(r) {
          return '<option value="' + r.id + '">' + r.nome + '</option>';
        }).join('');
        ['os-retiro', 'os-retiro-origem', 'os-retiro-destino'].forEach(function(id) {
          var sel = document.getElementById(id);
          if (sel) sel.innerHTML = '<option value="">Selecione o retiro</option>' + optsRetiro;
        });

        preselecionarRetiroLogado(d.retiros);

        CATEGORIAS = d.categorias;
        CATEGORIAS_NASCIMENTO = d.categoriasNascimento || [];

        var selCausa = document.getElementById('os-causa');
        selCausa.innerHTML = '<option value="">Selecione a causa</option>' +
          d.tiposMorte.map(function(c) { return '<option value="' + c + '">' + c + '</option>'; }).join('');
      })
      .catch(function() {
        mostrarMsg('❌ Erro ao carregar dados do servidor. Verifique a conexão.', 'erro');
      });
  }

  function preselecionarRetiroLogado(retiros) {
    var alvo = (RETIRO_LOGADO || '').trim().toLowerCase();
    if (!alvo) return;
    var match = retiros.find(function(r) {
      return String(r.id).toLowerCase() === alvo
          || String(r.nome).toLowerCase() === alvo;
    });
    if (!match) return;
    ['os-retiro', 'os-retiro-origem'].forEach(function(id) {
      var sel = document.getElementById(id);
      if (sel) sel.value = match.id;
    });
  }

  function configurarOperacao() {
    var inpOp = document.getElementById('os-operacao');
    inpOp.addEventListener('change', function() {
      var op = inpOp.value;
      document.querySelectorAll('.campo.dinamico').forEach(function(el) {
        var ops = el.getAttribute('data-op').split(' ');
        el.style.display = ops.indexOf(op) >= 0 ? 'block' : 'none';
      });
      document.getElementById('btn-enviar').disabled = !op;

      // Inicia com uma linha de categoria/evolução
      // Limpa as linhas antigas pra regenerar com a lista certa (nascimento = só bezerro/bezerra)
      if (['nascimento','obito','transferencia','compravenda'].indexOf(op) >= 0) {
        var cont = document.getElementById('linhas-categoria');
        cont.innerHTML = '';
        addLinhaCategoria();
        atualizarTotal();
      }
      if (op === 'evolucao') {
        var ce = document.getElementById('linhas-evolucao');
        if (!ce.children.length) addLinhaEvolucao();
      }
    });
  }

  function configurarToggles() {
    document.querySelectorAll('.toggle-pills').forEach(function(grupo) {
      grupo.querySelectorAll('.pill').forEach(function(btn) {
        btn.addEventListener('click', function() {
          grupo.querySelectorAll('.pill').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          if (btn.dataset.tipo) TIPO_TRANSF = btn.dataset.tipo;
          if (btn.dataset.negocio) TIPO_NEGOCIO = btn.dataset.negocio;
          if (btn.dataset.transporte) {
            TIPO_TRANSPORTE = btn.dataset.transporte;
            var bloco = document.getElementById('bloco-motorista');
            if (bloco) bloco.style.display = (TIPO_TRANSPORTE === 'rodoviario') ? 'block' : 'none';
          }
        });
      });
    });
  }

  function configurarFotoLabel() {
    var input = document.getElementById('os-foto');
    if (input) {
      input.addEventListener('change', function() {
        var txt = document.getElementById('foto-label-txt');
        if (input.files.length) txt.textContent = '✅ ' + input.files[0].name;
      });
    }
    var inputMan = document.getElementById('os-foto-manejo');
    if (inputMan) {
      inputMan.addEventListener('change', function() {
        var txt = document.getElementById('foto-manejo-txt');
        if (inputMan.files.length) txt.textContent = '✅ ' + inputMan.files[0].name;
      });
    }
  }

  function coletarCategorias() {
    var lista = [];
    document.querySelectorAll('#linhas-categoria .linha-cat').forEach(function(linha) {
      var cat = linha.querySelector('.cat-sel').value;
      var qtd = linha.querySelector('.cat-qtd').value;
      if (cat && qtd) lista.push({ categoria: cat, quantidade: parseInt(qtd) });
    });
    return lista;
  }

  function coletarEvolucoes() {
    var lista = [];
    document.querySelectorAll('#linhas-evolucao .linha-evo').forEach(function(linha) {
      lista.push({
        origem: linha.querySelector('.evo-origem').value,
        destino: linha.querySelector('.evo-destino').value,
        quantidade: parseInt(linha.querySelector('.evo-qtd').value) || 0
      });
    });
    return lista;
  }

  function mostrarMsg(texto, tipo) {
    var msg = document.getElementById('form-msg');
    msg.textContent = texto;
    msg.className = 'form-msg ' + tipo;
    msg.style.display = 'block';
    msg.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  document.getElementById('form-nova-os').addEventListener('submit', function(e) {
    e.preventDefault();
    var op = document.getElementById('os-operacao').value;

    if (op === 'obito') {
      if (!document.getElementById('os-foto').files.length) {
        mostrarMsg('📷 Para registrar óbito é obrigatório anexar a foto da carcaça.', 'erro');
        return;
      }
      if (!document.getElementById('os-causa').value) {
        mostrarMsg('💀 Informe a causa da morte.', 'erro');
        return;
      }
    }

    var obsTexto = ((document.getElementById('os-observacoes') || {}).value || '').trim();
    var exigeDetalhamento = ['obito', 'transferencia', 'compravenda', 'evolucao', 'manejo'].indexOf(op) >= 0;
    if (exigeDetalhamento && !obsTexto && !audioBase64) {
      mostrarMsg('Informe o detalhamento do registro por texto ou audio antes de salvar.', 'erro');
      return;
    }

    var payload = { operacao: op, perfil: PERFIL, data: (document.getElementById('os-data') || {}).value };

    if (['nascimento','obito','transferencia','compravenda'].indexOf(op) >= 0) {
      payload.animais = coletarCategorias();
      if (!payload.animais.length) {
        mostrarMsg('🐂 Adicione pelo menos uma categoria com quantidade.', 'erro');
        return;
      }
    }

    if (op === 'transferencia') {
      payload.tipo = TIPO_TRANSF;
      payload.transporte = TIPO_TRANSPORTE;
      payload.retiro_origem = document.getElementById('os-retiro-origem').value;
      payload.retiro_destino = document.getElementById('os-retiro-destino').value;
      // Dados de motorista não são mais solicitados (simplificação do formulário)
    } else if (op === 'compravenda') {
      payload.tipo = TIPO_NEGOCIO;
      payload.retiro = document.getElementById('os-retiro').value;
      payload.valor = document.getElementById('os-valor').value;
    } else if (op === 'nascimento') {
      payload.retiro = document.getElementById('os-retiro').value;
      payload.pasto = document.getElementById('os-pasto').value;
      payload.raca = document.getElementById('os-raca').value;
    } else if (op === 'obito') {
      payload.retiro = document.getElementById('os-retiro').value;
      payload.pasto = document.getElementById('os-pasto').value;
      payload.brinco = document.getElementById('os-brinco').value;
      payload.causa = document.getElementById('os-causa').value;
      var fotoObito = document.getElementById('os-foto');
      payload.tem_foto = !!(fotoObito && fotoObito.files.length);
    } else if (op === 'evolucao') {
      payload.retiro = document.getElementById('os-retiro').value;
      payload.evolucoes = coletarEvolucoes();
    } else if (op === 'manejo') {
      payload.retiro = document.getElementById('os-retiro').value;
      payload.titulo = document.getElementById('os-titulo').value;
      var fmInput = document.getElementById('os-foto-manejo');
      payload.tem_foto = !!(fmInput && fmInput.files.length);
    }
    payload.observacoes = obsTexto;
    payload.observacoes_audio = audioBase64 || ''; // áudio em base64 (data URL) para salvar no banco

    // Lê a foto (óbito ou manejo) como base64 antes de enviar
    var fotoFile = null;
    if (op === 'obito') {
      var fObito = document.getElementById('os-foto');
      if (fObito && fObito.files.length) fotoFile = fObito.files[0];
    } else if (op === 'manejo') {
      var fManejo = document.getElementById('os-foto-manejo');
      if (fManejo && fManejo.files.length) fotoFile = fManejo.files[0];
    }

    var lerFoto = fotoFile
      ? new Promise(function(resolve) {
          var r = new FileReader();
          r.onload = function() { resolve(r.result); };
          r.onerror = function() { resolve(''); };
          r.readAsDataURL(fotoFile);
        })
      : Promise.resolve('');

    lerFoto.then(function(fotoBase64) {
      if (fotoBase64) {
        payload.foto_base64 = fotoBase64;
        payload.tem_foto = true;
      }
      // Georreferência: captura GPS pra rastreabilidade (não bloqueia se negar)
      capturarGPS(function(coords) {
        if (coords) {
          payload.latitude = coords.latitude;
          payload.longitude = coords.longitude;
        }
        enviarPayload(payload);
      });
    });
  });

  // Captura GPS com timeout curto; chama cb(null) se falhar/negar (não trava o registro)
  function capturarGPS(cb) {
    if (!navigator.geolocation) { cb(null); return; }
    var respondido = false;
    var timer = setTimeout(function() { if (!respondido) { respondido = true; cb(null); } }, 4000);
    navigator.geolocation.getCurrentPosition(
      function(pos) {
        if (respondido) return;
        respondido = true; clearTimeout(timer);
        cb({ latitude: pos.coords.latitude, longitude: pos.coords.longitude });
      },
      function() { if (!respondido) { respondido = true; clearTimeout(timer); cb(null); } },
      { enableHighAccuracy: true, timeout: 4000, maximumAge: 60000 }
    );
  }

  function enviarPayload(payload) {
    var editId = new URLSearchParams(window.location.search).get('edit');
    var url = editId ? '/api/boletas/' + encodeURIComponent(editId) : '/api/boletas';
    var metodo = editId ? 'PUT' : 'POST';

    if (window.fazerRequisicaoComOffline) {
      window.fazerRequisicaoComOffline(url, { metodo: metodo, dados: payload, tipo: 'boleta' })
        .then(function(res) {
          if (!res.sucesso && !res.offline) {
            mostrarMsg('Erro ao salvar boleta: ' + (res.mensagem || 'tente novamente.'), 'erro');
            return;
          }
          try {
            var dados = res.dados || {};
            var resumo = Object.assign({ id: dados.grupo_id || res.idFila || editId || '', criadoEm: new Date().toISOString(), offline: !!res.offline }, payload);
            localStorage.setItem('brpec_ultimo_registro', JSON.stringify(resumo));
          } catch(e) {}
          window.location.href = '/sucesso';
        })
        .catch(function() {
          mostrarMsg('Nao foi possivel guardar no aparelho. Tente novamente.', 'erro');
        });
      return;
    }

    fetch(url, {
      method: metodo,
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(payload),
    })
    .then(function(r) { return r.json().then(function(d){ return { ok: r.ok, data: d }; }); })
    .then(function(res) {
      if (!res.ok) {
        mostrarMsg('❌ ' + (res.data.erro || 'Erro ao salvar boleta.'), 'erro');
        return;
      }
      // Guarda no localStorage só pra tela de sucesso mostrar o resumo
      try {
        var resumo = Object.assign({ id: res.data.grupo_id, criadoEm: new Date().toISOString() }, payload);
        localStorage.setItem('brpec_ultimo_registro', JSON.stringify(resumo));
      } catch(e) {}
      window.location.href = '/sucesso';
    })
    .catch(function() {
      mostrarMsg('❌ Erro de conexão. Tente novamente.', 'erro');
    });
  }
</script>

