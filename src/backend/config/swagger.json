            "example": 8
          },
          "em_andamento": {
            "type": "integer",
            "example": 3
          },
          "concluidas": {
            "type": "integer",
            "example": 29
          },
          "concluidas_hoje": {
            "type": "integer",
            "example": 5
          }
        }
      },
      "TarefasPorRetiro": {
        "type": "object",
        "properties": {
