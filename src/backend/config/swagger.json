              "EM_ANDAMENTO": 2,
              "CONCLUIDA": 12
            }
          }
        }
      },
      "AlertaAbertoPainel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "alerta-001"
          },
          "tipo": {
            "type": "string",
            "example": "CERCA_QUEBRADA"
          },
          "descricao": {
            "type": "string",
            "example": "Cerca rompida próxima ao retiro norte"
          },
          "status": {
            "type": "string",
