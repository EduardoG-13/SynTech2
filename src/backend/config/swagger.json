          },
          "capataz_id": {
            "type": "string",
            "example": "capataz-001"
          },
          "capataz_nome": {
            "type": "string",
            "example": "João Silva"
          },
          "retiro_id": {
            "type": "string",
            "example": "retiro-001"
          },
          "retiro_nome": {
            "type": "string",
            "example": "Retiro Norte"
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "example": -20.123456
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "example": -56.123456
          },
          "criado_em": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-10T10:00:00.000Z"
          }
        }
      },
      "ErroResponse": {
        "type": "object",
        "properties": {
          "erro": {
            "type": "string",
