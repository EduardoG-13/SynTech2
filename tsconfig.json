{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "src/backend",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src/backend/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/backend/__tests__/**",
    "src/backend/tests/**",
    "src/backend/jest.setup.env.ts"
  ]
}
